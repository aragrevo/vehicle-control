---
interface Props {
  totalCost: number;
  avgConsumption: number;
  ctaHref: string;
}

const { totalCost, avgConsumption, ctaHref } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-12 gap-lg">
  <div class="md:col-span-4 bg-surface-container border border-outline-variant rounded-xl p-md flex flex-col justify-between group hover:border-primary/50 transition-colors">
    <div>
      <div class="flex justify-between items-start mb-base">
        <span class="text-label-md text-on-surface-variant uppercase tracking-widest">Gasto total (30d)</span>
        <span class="material-symbols-outlined text-tertiary">monetization_on</span>
      </div>
      <div class="flex items-baseline gap-2">
        <p class="text-headline-lg font-headline-lg text-on-surface">{totalCost.toFixed(2)} €</p>
      </div>
    </div>
    <div class="mt-md h-12 w-full bg-surface-container-highest/30 rounded flex items-end gap-1 px-1 overflow-hidden">
      {Array.from({ length: 7 }).map((_, i) => (
        <div class={`flex-1 bg-primary/${20 + i * 12} rounded-t-sm`} style={`height: ${30 + i * 10}%`}></div>
      ))}
    </div>
  </div>

  <div class="md:col-span-4 bg-surface-container border border-outline-variant rounded-xl p-md flex flex-col justify-between group hover:border-primary/50 transition-colors">
    <div>
      <div class="flex justify-between items-start mb-base">
        <span class="text-label-md text-on-surface-variant uppercase tracking-widest">Consumo medio</span>
        <span class="material-symbols-outlined text-primary">analytics</span>
      </div>
      <div class="flex items-baseline gap-2">
        <p class="text-headline-lg font-headline-lg text-on-surface">
          {avgConsumption > 0 ? avgConsumption.toFixed(1) : '—'}
          {avgConsumption > 0 && <span class="text-body-md font-normal text-on-surface-variant ml-1">L/100km</span>}
        </p>
      </div>
    </div>
    {avgConsumption > 0 && (
      <div class="mt-md space-y-2">
        <div class="flex justify-between text-label-md text-on-surface-variant">
          <span>Objetivo</span>
          <span>8.0 L/100km</span>
        </div>
        <div class="w-full bg-surface-container-highest rounded-full h-2">
          <div class="bg-primary h-full rounded-full" style={`width: ${Math.min((8 / avgConsumption) * 100, 100)}%`}></div>
        </div>
      </div>
    )}
  </div>

  <a
    href={ctaHref}
    class="md:col-span-4 bg-primary-container/10 border-2 border-dashed border-primary/30 rounded-xl p-md flex flex-col items-center justify-center text-center group hover:bg-primary-container/20 hover:border-primary transition-all cursor-pointer"
  >
    <div class="w-12 h-12 bg-primary/20 text-primary rounded-full flex items-center justify-center mb-md group-hover:scale-110 transition-transform">
      <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">add</span>
    </div>
    <h3 class="text-headline-sm text-primary mb-1">Registrar Carga</h3>
    <p class="text-body-md text-on-surface-variant px-4">Registra una nueva carga y actualiza el odómetro.</p>
  </a>
</div>
