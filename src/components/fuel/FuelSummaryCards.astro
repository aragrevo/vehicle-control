---
import StatCard from "@/components/ui/StatCard.astro";

interface Props {
  totalCost: number;
  avgConsumption: number;
  ctaHref: string;
  costTrend?: number | null;
  consumptionTrend?: number | null;
  refuelCount?: number;
  avgPricePerLiter?: number;
  totalLiters?: number;
}

const {
  totalCost,
  avgConsumption,
  ctaHref,
  costTrend = null,
  consumptionTrend = null,
  refuelCount = 0,
  avgPricePerLiter = 0,
  totalLiters = 0,
} = Astro.props;
---

<div class="grid grid-cols-2 lg:grid-cols-6 gap-sm">
  <StatCard label="Cargas" value={refuelCount} icon="event" />

  <StatCard
    label="Litros Totales"
    value={totalLiters.toFixed(1)}
    icon="water_drop"
    colorClass="text-tertiary"
    bgClass="bg-tertiary/10"
    suffix="L"
  />

  <StatCard
    label="Gasto Total"
    value={`${totalCost.toFixed(2)} €`}
    icon="payments"
    colorClass="text-tertiary"
    bgClass="bg-tertiary/10"
    trend={costTrend}
  />

  <StatCard
    label="Consumo Medio"
    value={avgConsumption > 0 ? avgConsumption.toFixed(1) : "—"}
    icon="check_circle"
    suffix={avgConsumption > 0 ? "L/100km" : undefined}
    trend={consumptionTrend}
    trendInverted
  />

  <StatCard
    label="Precio Medio/L"
    value={avgPricePerLiter > 0 ? avgPricePerLiter.toFixed(3) : "—"}
    icon="sell"
    colorClass="text-warning"
    bgClass="bg-warning/10"
    suffix={avgPricePerLiter > 0 ? "€" : undefined}
  />
  <div
    class="bg-surface-container border border-outline-variant rounded-xl p-md flex flex-col items-start justify-between hover:border-primary/50 transition-colors"
  >
    <h5
      class="font-label-md text-label-md text-on-surface-variant uppercase mb-md"
    >
      Registrar Carga
    </h5>
    <a
      href={`/fuel/new`}
      class="w-full text-left p-md bg-surface-container-high hover:bg-surface-variant transition-colors rounded-lg flex items-center justify-between group border border-outline-variant/30"
    >
      <div class="flex items-center gap-md">
        <span
          class="material-symbols-outlined text-primary"
          style="font-variation-settings: 'FILL' 1;">ev_station</span
        >
        <span class="font-label-md">Nuevo</span>
      </div>
      <span
        class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform"
        >chevron_right</span
      >
    </a>
  </div>
</div>
