---
import StatCard from '@/components/ui/StatCard.astro';

interface Props {
  totalCost: number;
  avgConsumption: number;
  ctaHref: string;
  costTrend?: number | null;
  consumptionTrend?: number | null;
  refuelCount?: number;
  avgPricePerLiter?: number;
  totalLiters?: number;
}

const { totalCost, avgConsumption, ctaHref, costTrend = null, consumptionTrend = null, refuelCount = 0, avgPricePerLiter = 0, totalLiters = 0 } = Astro.props;
---

<div class="grid grid-cols-2 lg:grid-cols-6 gap-sm">
  <StatCard
    label="Cargas"
    value={refuelCount}
    icon="event"
  />

  <StatCard
    label="Litros Totales"
    value={totalLiters.toFixed(1)}
    icon="water_drop"
    colorClass="text-tertiary"
    bgClass="bg-tertiary/10"
    suffix="L"
  />

  <StatCard
    label="Gasto Total"
    value={`${totalCost.toFixed(2)} €`}
    icon="payments"
    colorClass="text-tertiary"
    bgClass="bg-tertiary/10"
    trend={costTrend}
  />

  <StatCard
    label="Consumo Medio"
    value={avgConsumption > 0 ? avgConsumption.toFixed(1) : '—'}
    icon="check_circle"
    suffix={avgConsumption > 0 ? 'L/100km' : undefined}
    trend={consumptionTrend}
    trendInverted
  />

  <StatCard
    label="Precio Medio/L"
    value={avgPricePerLiter > 0 ? avgPricePerLiter.toFixed(3) : '—'}
    icon="sell"
    colorClass="text-warning"
    bgClass="bg-warning/10"
    suffix={avgPricePerLiter > 0 ? '€' : undefined}
  />

  <a
    href={ctaHref}
    class="bg-primary-container/10 border-2 border-dashed border-primary/30 rounded-xl p-md flex items-center justify-center gap-md group hover:bg-primary-container/20 hover:border-primary transition-all cursor-pointer"
  >
    <div class="w-10 h-10 bg-primary/20 text-primary rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
      <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">add</span>
    </div>
    <div>
      <h3 class="text-headline-sm text-primary">Registrar Carga</h3>
    </div>
  </a>
</div>
