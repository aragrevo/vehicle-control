---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getDocumentStatus, getStatusLabel, getStatusVariant, getDocumentTypeLabel } from '../../lib/documents';

interface Props {
  documents: Array<{
    id: string;
    vehicleId: string;
    type: string;
    expiresAt: number | null;
    alertDaysBefore: number | null;
    fileUrl: string | null;
  }>;
  vehicleId?: string;
  showVehicleInfo?: boolean;
  vehicleName?: string;
}

const { documents, vehicleId, showVehicleInfo = false, vehicleName } = Astro.props;

const statusIcons = {
  valid: '✓',
  expiring: '⚠',
  expired: '✕',
  unknown: '?',
};
---

{documents.length === 0 ? (
  <div class="text-center py-lg">
    <div class="text-4xl mb-sm">📄</div>
    <p class="text-body-lg text-on-surface-variant">No hay documentos registrados</p>
    {vehicleId && (
      <Button href={`/documents?vehicle=${vehicleId}&new=true`} variant="primary" size="sm" class="mt-md">
        Añadir documento
      </Button>
    )}
  </div>
) : (
  <div class="space-y-xs">
    {documents.map((doc) => {
      const status = getDocumentStatus(doc.expiresAt, doc.alertDaysBefore ?? 30);
      return (
        <div class="flex items-center justify-between p-md bg-surface-container-low rounded-md hover:bg-surface-container transition-colors">
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 bg-surface-container-highest rounded-md flex items-center justify-center">
              <span class="text-lg">
                {doc.type === 'itv' ? '🔍' : doc.type === 'insurance' ? '🛡️' : '📋'}
              </span>
            </div>
            <div>
              <div class="flex items-center gap-sm">
                <p class="text-body-md font-medium text-on-surface">
                  {getDocumentTypeLabel(doc.type)}
                </p>
                {showVehicleInfo && vehicleName && (
                  <span class="text-label-md text-on-surface-variant">• {vehicleName}</span>
                )}
              </div>
              {doc.expiresAt && (
                <p class="text-label-md text-on-surface-variant mt-xs">
                  Vence: {new Date(doc.expiresAt).toLocaleDateString('es-ES')}
                  {status === 'expiring' && (
                    <span class="text-warning ml-sm">
                      (en {Math.ceil((doc.expiresAt - Date.now()) / (1000 * 60 * 60 * 24))} días)
                    </span>
                  )}
                </p>
              )}
            </div>
          </div>
          <div class="flex items-center gap-sm">
            <Badge variant={getStatusVariant(status)} icon={statusIcons[status]}>
              {getStatusLabel(status)}
            </Badge>
            {doc.fileUrl && (
              <a
                href={doc.fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-body-md text-primary hover:text-primary/80 transition-colors"
              >
                Ver archivo
              </a>
            )}
            <div class="flex items-center gap-xs">
              <Button href={`/documents/edit/${doc.id}`} variant="ghost" size="sm">
                Editar
              </Button>
              <form method="POST" action={`/api/documents/${doc.id}/delete`}>
                {vehicleId && <input type="hidden" name="vehicleId" value={vehicleId} />}
                <Button type="submit" variant="ghost" size="sm" class="text-error hover:text-error">
                  Eliminar
                </Button>
              </form>
            </div>
          </div>
        </div>
      );
    })}
  </div>
)}
