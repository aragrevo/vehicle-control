---
import Button from '../ui/Button.astro';

interface Props {
  vehicleId: string;
  maintenance?: {
    id: string;
    type: string;
    description: string | null;
    date: number | null;
    km: number | null;
    cost: number | null;
  };
  action: string;
}

const { vehicleId, maintenance, action } = Astro.props;

const maintenanceTypes = [
  { value: 'oil_change', label: 'Cambio de aceite' },
  { value: 'tires', label: 'Neumáticos' },
  { value: 'brakes', label: 'Frenos' },
  { value: 'revision', label: 'Revisión' },
  { value: 'other', label: 'Otro' },
];

const today = new Date().toISOString().split('T')[0];
---

<form method="POST" action={action} class="space-y-md">
  <input type="hidden" name="vehicleId" value={vehicleId} />

  <div>
    <label for="type" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
      Tipo de mantenimiento *
    </label>
    <select
      id="type"
      name="type"
      required
      class="select-base"
    >
      <option value="">Seleccionar...</option>
      {maintenanceTypes.map((type) => (
        <option
          value={type.value}
          selected={maintenance?.type === type.value}
        >
          {type.label}
        </option>
      ))}
    </select>
  </div>

  <div>
    <label for="description" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
      Descripción
    </label>
    <textarea
      id="description"
      name="description"
      rows="3"
      class="input-base"
      placeholder="Detalles del mantenimiento realizado..."
    >{maintenance?.description || ''}</textarea>
  </div>

  <div class="grid gap-md md:grid-cols-3">
    <div>
      <label for="date" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Fecha
      </label>
      <input
        type="date"
        id="date"
        name="date"
        value={maintenance?.date ? new Date(maintenance.date).toISOString().split('T')[0] : today}
        class="input-base"
      />
    </div>

    <div>
      <label for="km" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Kilometraje
      </label>
      <input
        type="number"
        id="km"
        name="km"
        min="0"
        value={maintenance?.km || ''}
        class="input-base font-mono"
        placeholder="50000"
      />
    </div>

    <div>
      <label for="cost" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Coste (€)
      </label>
      <input
        type="number"
        id="cost"
        name="cost"
        min="0"
        step="0.01"
        value={maintenance?.cost || ''}
        class="input-base font-mono"
        placeholder="150.00"
      />
    </div>
  </div>

  <div class="flex items-center gap-md pt-md border-t border-outline-variant">
    <Button type="submit" variant="primary">
      {maintenance ? 'Guardar cambios' : 'Registrar mantenimiento'}
    </Button>
    <Button href={`/maintenance/${vehicleId}`} variant="ghost">
      Cancelar
    </Button>
  </div>
</form>
