---
import Button from '../ui/Button.astro';

interface Props {
  maintenances: Array<{
    id: string;
    type: string;
    description: string | null;
    date: number | null;
    km: number | null;
    cost: number | null;
  }>;
  vehicleId: string;
}

const { maintenances, vehicleId } = Astro.props;

const maintenanceTypes: Record<string, string> = {
  oil_change: 'Cambio de aceite',
  tires: 'Neumáticos',
  brakes: 'Frenos',
  revision: 'Revisión',
  other: 'Otro',
};
---

{maintenances.length === 0 ? (
  <div class="text-center py-lg">
    <div class="text-4xl mb-sm">🔧</div>
    <p class="text-body-lg text-on-surface-variant">No hay mantenimientos registrados</p>
    <Button href={`/maintenance/${vehicleId}?new=true`} variant="primary" size="sm" class="mt-md">
      Añadir mantenimiento
    </Button>
  </div>
) : (
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-outline-variant">
          <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Tipo</th>
          <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Descripción</th>
          <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Fecha</th>
          <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Km</th>
          <th class="text-right text-label-md text-on-surface-variant uppercase pb-sm">Coste</th>
          <th class="text-right text-label-md text-on-surface-variant uppercase pb-sm">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant">
        {maintenances.map((m) => (
          <tr class="hover:bg-surface-container-high transition-colors">
            <td class="py-sm text-body-md text-on-surface font-medium">
              {maintenanceTypes[m.type] || m.type}
            </td>
            <td class="py-sm text-body-md text-on-surface-variant max-w-xs truncate">
              {m.description || '-'}
            </td>
            <td class="py-sm text-body-md text-on-surface-variant">
              {m.date ? new Date(m.date).toLocaleDateString('es-ES') : '-'}
            </td>
            <td class="py-sm font-mono text-data-mono text-on-surface-variant">
              {m.km?.toLocaleString() || '-'}
            </td>
            <td class="py-sm text-body-md text-on-surface text-right font-mono">
              {m.cost ? `${m.cost.toFixed(2)} €` : '-'}
            </td>
            <td class="py-sm text-right">
              <div class="flex items-center justify-end gap-xs">
                <Button href={`/maintenance/${vehicleId}/edit/${m.id}`} variant="ghost" size="sm">
                  Editar
                </Button>
                <form method="POST" action={`/api/maintenance/${m.id}/delete`}>
                  <input type="hidden" name="vehicleId" value={vehicleId} />
                  <Button type="submit" variant="ghost" size="sm" class="text-error hover:text-error">
                    Eliminar
                  </Button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
