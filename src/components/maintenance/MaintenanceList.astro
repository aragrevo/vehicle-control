---
import Button from '../ui/Button.astro';

interface Props {
  maintenances: Array<{
    id: string;
    type: string;
    description: string | null;
    date: number | null;
    km: number | null;
    cost: number | null;
  }>;
  vehicleId: string;
}

const { maintenances, vehicleId } = Astro.props;

const maintenanceTypes: Record<string, string> = {
  oil_change: 'Cambio de aceite',
  tires: 'Neumáticos',
  brakes: 'Frenos',
  revision: 'Revisión',
  other: 'Otro',
};
---

{maintenances.length === 0 ? (
  <div class="text-center py-8">
    <div class="text-4xl mb-3">🔧</div>
    <p class="text-gray-500">No hay mantenimientos registrados</p>
    <Button href={`/maintenance/${vehicleId}?new=true`} variant="primary" size="sm" class="mt-4">
      Añadir mantenimiento
    </Button>
  </div>
) : (
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Tipo</th>
          <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Descripción</th>
          <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Fecha</th>
          <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Km</th>
          <th class="text-right text-xs font-medium text-gray-500 uppercase pb-3">Coste</th>
          <th class="text-right text-xs font-medium text-gray-500 uppercase pb-3">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {maintenances.map((m) => (
          <tr>
            <td class="py-3 text-sm font-medium text-gray-900">
              {maintenanceTypes[m.type] || m.type}
            </td>
            <td class="py-3 text-sm text-gray-500 max-w-xs truncate">
              {m.description || '-'}
            </td>
            <td class="py-3 text-sm text-gray-500">
              {m.date ? new Date(m.date).toLocaleDateString('es-ES') : '-'}
            </td>
            <td class="py-3 text-sm text-gray-500">
              {m.km?.toLocaleString() || '-'}
            </td>
            <td class="py-3 text-sm text-gray-900 text-right">
              {m.cost ? `${m.cost.toFixed(2)} €` : '-'}
            </td>
            <td class="py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <Button href={`/maintenance/${vehicleId}/edit/${m.id}`} variant="ghost" size="sm">
                  Editar
                </Button>
                <form method="POST" action={`/api/maintenance/${m.id}/delete`}>
                  <input type="hidden" name="vehicleId" value={vehicleId} />
                  <Button type="submit" variant="ghost" size="sm" class="text-red-600 hover:text-red-700">
                    Eliminar
                  </Button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
