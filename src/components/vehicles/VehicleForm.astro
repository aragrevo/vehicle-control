---
import Button from '../ui/Button.astro';

interface Props {
  vehicle?: {
    id: string;
    plate: string;
    vin: string | null;
    brand: string;
    model: string;
    year: number | null;
    color: string | null;
    fuelType: string | null;
    km: number | null;
  };
  action: string;
}

const { vehicle, action } = Astro.props;

const fuelTypes = [
  { value: 'gasoline', label: 'Gasolina' },
  { value: 'diesel', label: 'Diésel' },
  { value: 'electric', label: 'Eléctrico' },
  { value: 'hybrid', label: 'Híbrido' },
  { value: 'lpg', label: 'GLP' },
  { value: 'cng', label: 'GNC' },
];
---

<form method="POST" action={action} class="space-y-md">
  <div class="grid gap-md md:grid-cols-2">
    <div>
      <label for="plate" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Matrícula *
      </label>
      <input
        type="text"
        id="plate"
        name="plate"
        required
        value={vehicle?.plate || ''}
        class="input-base font-mono uppercase"
        placeholder="1234 ABC"
      />
    </div>

    <div>
      <label for="vin" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        VIN
      </label>
      <input
        type="text"
        id="vin"
        name="vin"
        value={vehicle?.vin || ''}
        class="input-base font-mono uppercase"
        placeholder="WVWZZZ3CZWE123456"
      />
    </div>

    <div>
      <label for="brand" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Marca *
      </label>
      <input
        type="text"
        id="brand"
        name="brand"
        required
        value={vehicle?.brand || ''}
        class="input-base"
        placeholder="Volkswagen"
      />
    </div>

    <div>
      <label for="model" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Modelo *
      </label>
      <input
        type="text"
        id="model"
        name="model"
        required
        value={vehicle?.model || ''}
        class="input-base"
        placeholder="Golf"
      />
    </div>

    <div>
      <label for="year" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Año
      </label>
      <input
        type="number"
        id="year"
        name="year"
        min="1900"
        max="2099"
        value={vehicle?.year || ''}
        class="input-base"
        placeholder="2024"
      />
    </div>

    <div>
      <label for="color" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Color
      </label>
      <input
        type="text"
        id="color"
        name="color"
        value={vehicle?.color || ''}
        class="input-base"
        placeholder="Blanco"
      />
    </div>

    <div>
      <label for="fuelType" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Tipo de combustible
      </label>
      <select
        id="fuelType"
        name="fuelType"
        class="select-base"
      >
        <option value="">Seleccionar...</option>
        {fuelTypes.map((fuel) => (
          <option
            value={fuel.value}
            selected={vehicle?.fuelType === fuel.value}
          >
            {fuel.label}
          </option>
        ))}
      </select>
    </div>

    <div>
      <label for="km" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
        Kilometraje
      </label>
      <input
        type="number"
        id="km"
        name="km"
        min="0"
        value={vehicle?.km || ''}
        class="input-base font-mono"
        placeholder="50000"
      />
    </div>
  </div>

  <div class="flex items-center gap-md pt-md border-t border-outline-variant">
    <Button type="submit" variant="primary">
      {vehicle ? 'Guardar cambios' : 'Crear vehículo'}
    </Button>
    <Button href="/vehicles" variant="ghost">
      Cancelar
    </Button>
  </div>
</form>
