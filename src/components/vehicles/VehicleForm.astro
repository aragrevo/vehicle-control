---
import Button from "@/components/ui/Button.astro";

interface Props {
  vehicle?: {
    id: string;
    plate: string;
    vin: string | null;
    brand: string;
    model: string;
    year: number | null;
    color: string | null;
    fuelType: string | null;
    km: number | null;
    nextItvDate: number | null;
    insuranceExpiry: number | null;
    oilChangeReminder: boolean | null;
    nextRevisionKm: number | null;
    revisionIntervalKm: number | null;
    photos: string | null;
  };
  action: string;
}

const { vehicle, action } = Astro.props;

const existingPhotos: string[] = vehicle?.photos
  ? JSON.parse(vehicle.photos)
  : [];

const fuelTypes = [
  { value: "gasoline", label: "Gasolina" },
  { value: "diesel", label: "Diésel" },
  { value: "electric", label: "Eléctrico" },
  { value: "hybrid", label: "Híbrido" },
  { value: "lpg", label: "GLP" },
  { value: "cng", label: "GNC" },
];
---

<form
  class="space-y-xl relative"
  id="vehicleForm"
  method="POST"
  action={action}
>
  <!-- Loading Overlay -->
  <div
    id="formLoader"
    class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 items-center justify-center"
  >
    <div class="bg-surface-container rounded-2xl p-8 flex flex-col items-center gap-4 shadow-2xl">
      <div class="relative w-16 h-16">
        <div class="absolute inset-0 border-4 border-primary/20 rounded-full"></div>
        <div class="absolute inset-0 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
      </div>
      <div class="text-center">
        <p class="font-headline-sm text-headline-sm text-on-surface">Guardando vehículo</p>
        <p class="text-body-md text-on-surface-variant mt-1">Procesando imágenes...</p>
      </div>
    </div>
  </div>

  <!-- Section 1: Identification -->
  <section
    class="bg-surface-container rounded-xl p-md lg:p-xl border border-outline-variant"
  >
    <div class="flex items-center gap-2 mb-md">
      <span class="material-symbols-outlined text-primary">fingerprint</span>
      <h2 class="font-headline-sm text-headline-sm text-on-surface">
        Identificación del Vehículo
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
      <div>
        <label
          for="plate"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Matrícula</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-data-mono text-on-surface focus-ring uppercase"
          placeholder="1234 ABC"
          type="text"
          id="plate"
          name="plate"
          required
          value={vehicle?.plate || ""}
        />
      </div>
      <div class="md:col-span-2">
        <label
          for="vin"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Número de Bastidor (VIN)</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-data-mono text-on-surface focus-ring"
          placeholder="WBA1234567890ABCDE"
          type="text"
          id="vin"
          name="vin"
          value={vehicle?.vin || ""}
        />
      </div>
      <div>
        <label
          for="brand"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Marca</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm text-on-surface focus-ring"
          placeholder="Volkswagen"
          type="text"
          id="brand"
          name="brand"
          required
          value={vehicle?.brand || ""}
        />
      </div>
      <div>
        <label
          for="model"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Modelo</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm text-on-surface focus-ring"
          placeholder="Golf"
          type="text"
          id="model"
          name="model"
          required
          value={vehicle?.model || ""}
        />
      </div>
      <div>
        <label
          for="year"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Año</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm text-on-surface focus-ring"
          id="year"
          name="year"
          min="1900"
          max="2099"
          value={vehicle?.year || ""}
          placeholder="2024"
        />
      </div>
      <div>
        <label
          for="color"
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Color</label
        >
        <input
          class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm text-on-surface focus-ring"
          placeholder="Blanco Perla"
          type="text"
          id="color"
          name="color"
          value={vehicle?.color || ""}
        />
      </div>
      <div>
        <label
          class="block font-label-md text-label-md text-on-surface-variant mb-base"
          >Tipo de Combustible</label
        >
        <input
          type="hidden"
          name="fuelType"
          id="fuelType"
          value={vehicle?.fuelType || ""}
        />
        <div class="flex gap-2" id="fuelTypeButtons">
          {
            fuelTypes.map((fuel) => (
              <button
                data-value={fuel.value}
                class={`flex-1 py-sm rounded-lg font-label-md text-label-md border px-2.5 transition-all ${
                  vehicle?.fuelType === fuel.value
                    ? "bg-primary text-on-primary border-primary"
                    : "bg-secondary-container text-on-secondary-container border-primary/20 hover:border-primary/50"
                }`}
                type="button"
              >
                {fuel.label}
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <!-- Section 2: Mileage & Analytics -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-xl">
    <section
      class="bg-surface-container rounded-xl p-md lg:p-xl border border-outline-variant"
    >
      <div class="flex items-center gap-2 mb-md">
        <span class="material-symbols-outlined text-primary">speed</span>
        <h2 class="font-headline-sm text-headline-sm text-on-surface">
          Kilometraje
        </h2>
      </div>
      <div class="space-y-md">
        <div>
          <label
            for="km"
            class="block font-label-md text-label-md text-on-surface-variant mb-base"
            >Odómetro Actual (km)</label
          >
          <div class="relative">
            <input
              class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg pl-md pr-12 py-sm font-data-mono text-on-surface focus-ring text-right"
              type="number"
              id="km"
              name="km"
              value={vehicle?.km ?? 0}
            />
            <span
              class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xs"
              >KM</span
            >
          </div>
        </div>
        <div>
          <label
            for="nextRevisionKm"
            class="block font-label-md text-label-md text-on-surface-variant mb-base"
            >Proyección Próxima Revisión</label
          >
          <div class="relative">
            <input
              class="w-full bg-surface-container-low border border-outline-variant rounded-lg pl-md pr-12 py-sm font-data-mono text-on-surface-variant cursor-not-allowed text-right"
              type="number"
              id="nextRevisionKm"
              name="nextRevisionKm"
              value={vehicle?.nextRevisionKm ?? 15000}
              readonly
            />
            <span
              class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xs"
              >KM</span
            >
          </div>
        </div>
        <div id="revisionIntervalContainer">
          <label
            class="block font-label-md text-label-md text-on-surface-variant mb-base"
            >Intervalo entre Revisiones</label
          >
          <div
            class="bg-surface-container-low p-md rounded-lg border border-outline-variant/30 flex items-center justify-between"
            id="revisionIntervalDisplay"
          >
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-secondary"
                >trending_up</span
              >
              <div>
                <p class="text-xs text-on-surface-variant">
                  Intervalo sugerido
                </p>
                <p
                  class="font-label-md text-label-md"
                  id="revisionIntervalText"
                >
                  Cada {(vehicle?.revisionIntervalKm || 15000).toLocaleString()} km
                </p>
              </div>
            </div>
            <button
              type="button"
              id="editRevisionInterval"
              class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-primary transition-colors"
              >edit</button
            >
          </div>
          <div class="hidden relative" id="revisionIntervalInput">
            <input
              class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg pl-md pr-12 py-sm font-data-mono text-on-surface focus-ring text-right"
              type="number"
              id="revisionIntervalKm"
              name="revisionIntervalKm"
              value={vehicle?.revisionIntervalKm || 15000}
            />
            <span
              class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xs"
              >KM</span
            >
          </div>
        </div>
      </div>
    </section>
    <!-- Section 3: Alerts -->
    <section
      class="bg-surface-container rounded-xl p-md lg:p-xl border border-outline-variant"
    >
      <div class="flex items-center gap-2 mb-md">
        <span class="material-symbols-outlined text-primary"
          >notifications_active</span
        >
        <h2 class="font-headline-sm text-headline-sm text-on-surface">
          Alertas de Mantenimiento
        </h2>
      </div>
      <div class="space-y-md">
        <div
          class="flex items-center justify-between p-sm border-b border-outline-variant pb-md"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-lg bg-tertiary-container/20 flex items-center justify-center"
            >
              <span class="material-symbols-outlined text-tertiary"
                >calendar_today</span
              >
            </div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">
                Próxima ITV
              </p>
              <p class="text-[10px] text-on-surface-variant uppercase">
                Fecha de vencimiento
              </p>
            </div>
          </div>
          <input
            class="bg-surface-container-lowest border-outline-variant rounded px-2 py-1 text-xs text-on-surface focus-ring"
            type="date"
            name="nextItvDate"
            value={vehicle?.nextItvDate
              ? new Date(vehicle.nextItvDate).toISOString().split("T")[0]
              : ""}
          />
        </div>
        <div
          class="flex items-center justify-between p-sm border-b border-outline-variant pb-md"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-lg bg-primary-container/20 flex items-center justify-center"
            >
              <span class="material-symbols-outlined text-primary"
                >verified_user</span
              >
            </div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">Seguro</p>
              <p class="text-[10px] text-on-surface-variant uppercase">
                Vencimiento Póliza
              </p>
            </div>
          </div>
          <input
            class="bg-surface-container-lowest border-outline-variant rounded px-2 py-1 text-xs text-on-surface focus-ring"
            type="date"
            name="insuranceExpiry"
            value={vehicle?.insuranceExpiry
              ? new Date(vehicle.insuranceExpiry).toISOString().split("T")[0]
              : ""}
          />
        </div>
        <div class="flex items-center justify-between p-sm">
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-lg bg-error-container/20 flex items-center justify-center"
            >
              <span class="material-symbols-outlined text-error"
                >oil_barrel</span
              >
            </div>
            <div>
              <p class="font-label-md text-label-md text-on-surface">
                Cambio de Aceite
              </p>
              <p class="text-[10px] text-on-surface-variant uppercase">
                Recordatorio preventivo
              </p>
            </div>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input
              checked={vehicle?.oilChangeReminder !== false}
              class="sr-only peer"
              type="checkbox"
              name="oilChangeReminder"
              value="true"
            />
            <div
              class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"
            >
            </div>
          </label>
        </div>
      </div>
    </section>
  </div>
  <!-- Section 4: Photos & Documents -->
  <section
    class="bg-surface-container rounded-xl p-md lg:p-xl border border-outline-variant"
  >
    <div class="flex items-center gap-2 mb-md">
      <span class="material-symbols-outlined text-primary">add_a_photo</span>
      <h2 class="font-headline-sm text-headline-sm text-on-surface">
        Galería y Documentación
      </h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-md" id="photosGrid">
      <label
        for="photoUpload"
        class="aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center gap-2 cursor-pointer hover:bg-surface-container-high transition-all group"
      >
        <span
          class="material-symbols-outlined text-on-surface-variant group-hover:scale-110 transition-transform"
          >upload_file</span
        >
        <p class="text-[10px] font-bold text-on-surface-variant uppercase">
          Subir Foto
        </p>
        <input
          type="file"
          id="photoUpload"
          name="photos"
          accept="image/*"
          multiple
          class="hidden"
        />
      </label>
      {
        existingPhotos.map((photo, index) => (
          <div
            class="relative group aspect-square rounded-xl overflow-hidden border border-outline-variant"
            data-photo-index={index}
          >
            <img
              class="w-full h-full object-cover"
              src={photo}
              alt={`Foto ${index + 1}`}
            />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <button
                class="p-2 bg-error rounded-full text-white shadow-lg delete-photo"
                type="button"
                data-index={index}
              >
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          </div>
        ))
      }
    </div>
  </section>
  <!-- Footer Actions -->
  <div class="flex items-center justify-end gap-md pb-xl">
    <button
      class="px-xl py-sm rounded-lg font-label-md text-label-md text-on-surface-variant hover:bg-surface-container-high transition-all"
      type="button"
    >
      Cancelar
    </button>
    <button
      class="px-xl py-sm rounded-lg font-label-md text-label-md bg-primary text-on-primary font-bold shadow-lg shadow-primary/20 hover:opacity-90 active:scale-95 transition-all flex items-center gap-2"
      type="submit"
    >
      <span
        class="material-symbols-outlined text-sm"
        style="font-variation-settings: 'FILL' 1;">save</span
      >
      Guardar Vehículo
    </button>
  </div>
</form>

<script>
  const fuelTypeInput = document.getElementById("fuelType") as HTMLInputElement;
  const fuelTypeButtons = document.getElementById("fuelTypeButtons");

  if (fuelTypeButtons && fuelTypeInput) {
    fuelTypeButtons.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button");
      if (!btn) return;

      const value = btn.dataset.value;
      fuelTypeInput.value = value || "";

      fuelTypeButtons.querySelectorAll("button").forEach((b) => {
        b.className = b.className.replace(
          /bg-primary text-on-primary border-primary/,
          "bg-secondary-container text-on-secondary-container border-primary/20",
        );
      });

      btn.className = btn.className.replace(
        /bg-secondary-container text-on-secondary-container border-primary\/20/,
        "bg-primary text-on-primary border-primary",
      );
    });
  }

  const photoUpload = document.getElementById(
    "photoUpload",
  ) as HTMLInputElement;
  const photosGrid = document.getElementById("photosGrid");
  const form = document.getElementById("vehicleForm") as HTMLFormElement;

  const dataTransfer = new DataTransfer();

  function compressImage(file: File, maxWidth = 1200, quality = 0.7): Promise<File> {
    return new Promise((resolve) => {
      if (file.size < 500 * 1024) {
        resolve(file);
        return;
      }

      const canvas = document.createElement("canvas");
      const ctx = canvas.getContext("2d");
      const img = new Image();

      img.onload = () => {
        let width = img.width;
        let height = img.height;

        if (width > maxWidth) {
          height = (height * maxWidth) / width;
          width = maxWidth;
        }

        canvas.width = width;
        canvas.height = height;
        ctx?.drawImage(img, 0, 0, width, height);

        canvas.toBlob(
          (blob) => {
            if (blob) {
              resolve(new File([blob], file.name, { type: "image/jpeg" }));
            } else {
              resolve(file);
            }
          },
          "image/jpeg",
          quality,
        );
      };

      img.src = URL.createObjectURL(file);
    });
  }

  let photosModified = false;

  if (photoUpload && photosGrid) {
    photoUpload.addEventListener("change", async (e) => {
      const input = e.target as HTMLInputElement;
      if (!input.files) return;

      photosModified = true;
      const files = Array.from(input.files);

      for (const file of files) {
        const compressedFile = await compressImage(file);
        dataTransfer.items.add(compressedFile);

        const reader = new FileReader();
        reader.onload = (ev) => {
          const preview = document.createElement("div");
          preview.className =
            "relative group aspect-square rounded-xl overflow-hidden border border-outline-variant";
          preview.innerHTML = `
            <img class="w-full h-full object-cover" src="${ev.target?.result}" alt="${file.name}" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <button class="p-2 bg-error rounded-full text-white shadow-lg" type="button">
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          `;
          preview.querySelector("button")?.addEventListener("click", () => {
            preview.remove();
          });
          photosGrid.insertBefore(
            preview,
            photosGrid.querySelector("label")?.nextSibling || null,
          );
        };
        reader.readAsDataURL(compressedFile);
      }

      input.files = dataTransfer.files;
    });

    document.querySelectorAll(".delete-photo").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const button = e.currentTarget as HTMLButtonElement;
        const container = button.closest("[data-photo-index]");
        const index = button.dataset.index;

        photosModified = true;

        if (form && index !== undefined) {
          const hiddenInput = document.createElement("input");
          hiddenInput.type = "hidden";
          hiddenInput.name = "deletePhotoIndex";
          hiddenInput.value = index;
          form.appendChild(hiddenInput);
        }

        container?.remove();
      });
    });
  }

  if (form) {
    form.addEventListener("submit", (e) => {
      const hasFiles = dataTransfer.items.length > 0;
      
      if (hasFiles || photosModified) {
        form.enctype = "multipart/form-data";
      } else {
        form.enctype = "application/x-www-form-urlencoded";
        if (photoUpload) {
          photoUpload.disabled = true;
        }
      }

      const loader = document.getElementById("formLoader");
      if (loader && hasFiles) {
        loader.classList.remove("hidden");
        loader.classList.add("flex");
      }
    });
  }

  const editRevisionInterval = document.getElementById("editRevisionInterval");
  const revisionIntervalDisplay = document.getElementById(
    "revisionIntervalDisplay",
  );
  const revisionIntervalInput = document.getElementById(
    "revisionIntervalInput",
  );
  const revisionIntervalKm = document.getElementById(
    "revisionIntervalKm",
  ) as HTMLInputElement;
  const revisionIntervalText = document.getElementById("revisionIntervalText");

  if (
    editRevisionInterval &&
    revisionIntervalDisplay &&
    revisionIntervalInput
  ) {
    editRevisionInterval.addEventListener("click", () => {
      revisionIntervalDisplay.classList.add("hidden");
      revisionIntervalInput.classList.remove("hidden");
      revisionIntervalKm.focus();
    });

    revisionIntervalKm.addEventListener("blur", () => {
      const value = parseInt(revisionIntervalKm.value) || 15000;
      revisionIntervalText &&
        (revisionIntervalText.textContent = `Cada ${value.toLocaleString()} km`);
      revisionIntervalDisplay.classList.remove("hidden");
      revisionIntervalInput.classList.add("hidden");
      calculateNextRevision();
    });
  }

  const kmInput = document.getElementById("km") as HTMLInputElement;
  const nextRevisionKmInput = document.getElementById("nextRevisionKm") as HTMLInputElement;

  function calculateNextRevision() {
    if (kmInput && nextRevisionKmInput && revisionIntervalKm) {
      const currentKm = parseInt(kmInput.value) || 0;
      const interval = parseInt(revisionIntervalKm.value) || 15000;
      const nextRevision = Math.ceil((currentKm + interval) / 1000) * 1000;
      nextRevisionKmInput.value = nextRevision.toString();
    }
  }

  if (kmInput) {
    kmInput.addEventListener("input", calculateNextRevision);
  }
</script>
