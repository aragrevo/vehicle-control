---
interface Props {
  id: string;
  plate: string;
  brand: string;
  model: string;
  year: number | null;
  km: number | null;
  status: string | null;
  photos?: string | null;
}

const { id, plate, brand, model, year, km, status, photos } = Astro.props;

const photosList: string[] = photos ? JSON.parse(photos) : [];
const mainPhoto = photosList.length > 0 ? photosList[0] : null;

const statusConfig = {
  active: {
    label: "Al día",
    class: "bg-green-500/10 text-green-400 border border-green-500/20",
    icon: "check_circle",
  },
  inactive: {
    label: "Inactivo",
    class: "bg-error/10 text-error border border-error/20",
    icon: "warning",
  },
};

const currentStatus =
  statusConfig[status as keyof typeof statusConfig] || statusConfig.active;
---

<article
  class="bg-surface-container border border-outline-variant rounded-xl overflow-hidden card-glow transition-all group flex flex-col"
>
  <header
    class="relative h-48 w-full overflow-hidden bg-surface-container-lowest"
  >
    <img
      class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-500"
      alt={`${brand} ${model}`}
      src={mainPhoto ||
        "https://lh3.googleusercontent.com/aida-public/AB6AXuBk84cQe-WFkDrjwsspjfJXyJO-lJUguOQCfJLdcdu_Q3BcKlyB1kJVo8POGtW_s9wLGXMNPqmEPaeYlcVoLM0Os8q_UnJBKMVpe_ulwoSRPkMXlNS-4WIAIG5OfcemW6dOLFZXYwMOi5we9A9i8OHC3SOr8GhdKD8yAov9etscZhoKXP0sy8rKw1OZOA1z2gpkfk2iHmlk32Q4vyH9bFO4DwfubNCj17muEW5O-UAnYtbvUSwj5JWStOyBb89L_2z6XRn_TgZ7_IMT"}
    />
    <div class="absolute top-md right-md">
      <span
        class={`flex items-center gap-1.5 px-3 py-1 rounded-full font-label-md ${currentStatus.class}`}
      >
        <span
          class="material-symbols-outlined text-[14px]"
          data-icon="check_circle"
          style="font-variation-settings: 'FILL' 1;">{currentStatus.icon}</span
        >
        {currentStatus.label}
      </span>
    </div>
  </header>
  <div class="p-md space-y-md flex-1 flex flex-col">
    <div class="flex justify-between items-start">
      <div>
        <h3 class="font-headline-sm text-headline-sm text-on-surface">
          {brand}
        </h3>
        <p class="text-on-surface-variant font-label-md mt-1">
          {model}
        </p>
      </div>
      <span
        class="font-data-mono text-data-mono px-2 py-1 bg-surface-container-highest rounded border border-outline-variant text-primary"
      >
        {plate}
      </span>
    </div>
    <div
      class="flex items-center justify-between text-on-surface-variant font-label-md pt-2"
    >
      <div class="flex items-center gap-1">
        <span
          class="material-symbols-outlined text-[18px]"
          data-icon="calendar_today">calendar_today</span
        >
        {year}
      </div>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-[18px]" data-icon="speed"
          >speed</span
        >
        {km?.toLocaleString()} km
      </div>
    </div>
    <div
      class="pt-md mt-auto border-t border-outline-variant flex justify-between"
    >
      <div class="flex gap-2">
        <a
          href={`/vehicles/${id}`}
          class="p-2 rounded-lg bg-surface-container-highest text-on-surface hover:text-primary transition-colors"
          title="Editar"
        >
          <span class="material-symbols-outlined">edit</span>
        </a>
        <a
          href={`/fuel/new?vehicle=${id}`}
          class="p-2 rounded-lg bg-surface-container-highest text-on-surface hover:text-primary transition-colors"
          title="Combustible"
        >
          <span
            class="material-symbols-outlined text-primary"
            style="font-variation-settings: 'FILL' 1;">ev_station</span
          >
        </a>
      </div>
      <a
        href={`/maintenance/new?vehicleId=${id}`}
        class="p-2 rounded-lg bg-surface-container-highest text-on-surface hover:text-primary transition-colors"
        title="Mantenimiento"
      >
        <span
          class="material-symbols-outlined text-tertiary"
          style="font-variation-settings: 'FILL' 1;">calendar_month</span
        >
      </a>
    </div>
  </div>
</article>

<script>
  document.querySelectorAll(".card-glow").forEach((card) => {
    card.addEventListener("mousedown", () => {
      (card as HTMLElement).style.transform = "scale(0.98)";
    });
    card.addEventListener("mouseup", () => {
      (card as HTMLElement).style.transform = "scale(1)";
    });
    card.addEventListener("mouseleave", () => {
      (card as HTMLElement).style.transform = "scale(1)";
    });
  });
</script>
