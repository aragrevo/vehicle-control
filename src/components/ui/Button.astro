---
interface Props {
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'danger' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const {
  type = 'button',
  variant = 'primary',
  size = 'md',
  href,
  class: className = '',
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-md transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-surface';

const variants = {
  primary: 'bg-primary text-on-primary hover:bg-primary/90 focus:ring-primary',
  secondary: 'bg-secondary-container text-on-secondary-container hover:bg-secondary-container/80 focus:ring-secondary',
  danger: 'bg-error text-on-error hover:bg-error/90 focus:ring-error',
  ghost: 'bg-transparent text-on-surface-variant hover:bg-surface-container-high focus:ring-outline',
};

const sizes = {
  sm: 'px-sm py-xs text-label-md',
  md: 'px-md py-sm text-body-md',
  lg: 'px-lg py-md text-body-lg',
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
