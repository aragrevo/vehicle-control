---
interface Props {
  class?: string;
  padding?: boolean;
  interactive?: boolean;
}

const { class: className = '', padding = true, interactive = false } = Astro.props;
---

<div class={`bg-surface-container rounded-lg border border-outline-variant ${padding ? 'p-md' : ''} ${interactive ? 'card-interactive cursor-pointer' : ''} ${className}`}>
  <slot />
</div>
