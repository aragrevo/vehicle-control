---
import MaintenanceStats from "@/components/maintenance/MaintenanceStats.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { getUserMaintenances } from "@/lib/maintenance-service";
import { getUserVehicles } from "@/lib/vehicle-service";
import { MAINTENANCE_TYPE_LABELS } from "@/lib/vehicle-service";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { vehicles, maintenances: allMaintenances } = await getUserMaintenances(
  Astro.locals.user.id,
);

const typeIcons: Record<string, string> = {
  oil_change: "oil_barrel",
  tires: "tire_repair",
  brakes: "disc_full",
  revision: "settings_suggest",
  other: "handyman",
};

const totalRecords = allMaintenances.length;
const totalCost = allMaintenances.reduce((sum, m) => sum + (m.cost || 0), 0);

const now = new Date();
const thisMonth = allMaintenances.filter((m) => {
  if (!m.date) return false;
  const d = new Date(m.date);
  return (
    d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear()
  );
}).length;
---

<AppLayout title="Mantenimiento">
  <div class="space-y-lg">
    <!-- Content Body -->
    <div
      class="flex-1 overflow-y-auto p-md md:p-lg space-y-lg custom-scrollbar"
    >
      <!-- Page Hero / Stat Summary -->

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-lg pb-lg">
        <div class="glass-card rounded-xl p-md border border-outline-variant">
          <h5
            class="font-label-md text-label-md text-on-surface-variant uppercase mb-md"
          >
            Próximas ITV
          </h5>
          <div class="space-y-md">
            {
              vehicles
                .filter((v) => v.nextItvDate)
                .slice(0, 2)
                .map((vehicle) => {
                  const daysLeft = Math.ceil(
                    (new Date(vehicle.nextItvDate!) - new Date()) /
                      (1000 * 60 * 60 * 24),
                  );
                  return (
                    <div class="flex items-center justify-between p-sm rounded bg-surface-container-high">
                      <div class="flex items-center gap-sm">
                        <span class="font-data-mono text-data-mono text-primary">
                          {vehicle.plate}
                        </span>
                        <span class="text-on-surface-variant text-[12px]">
                          {daysLeft > 0
                            ? `En ${daysLeft} días`
                            : `Hace ${Math.abs(daysLeft)} días`}
                        </span>
                      </div>
                      <span
                        class={`material-symbols-outlined text-[18px] ${daysLeft <= 14 ? "text-error" : "text-on-surface-variant"}`}
                      >
                        {daysLeft <= 14 ? "notification_important" : "event"}
                      </span>
                    </div>
                  );
                })
            }
            {
              vehicles.filter((v) => v.nextItvDate).length === 0 && (
                <p class="text-on-surface-variant text-sm">
                  Sin ITV programadas
                </p>
              )
            }
          </div>
        </div>

        <div class="glass-card rounded-xl p-md border border-outline-variant">
          <div class="flex items-start justify-between pb-sm">
            <h5
              class="font-label-md text-label-md text-on-surface-variant uppercase mb-md"
            >
              Próximas Revisiones
            </h5>
            <div
              class={`w-10 h-10 rounded-lg bg-error/10 flex items-center justify-center`}
            >
              <span class={`material-symbols-outlined text-error`}>warning</span
              >
            </div>
          </div>
          <div class="space-y-md">
            {
              vehicles
                .filter((v) => v.nextRevisionKm && v.km)
                .slice(0, 2)
                .map((vehicle) => {
                  const kmLeft = vehicle.nextRevisionKm! - vehicle.km!;
                  return (
                    <div class="flex items-center justify-between p-sm rounded bg-surface-container-high">
                      <div class="flex items-center gap-sm">
                        <span class="font-data-mono text-data-mono text-primary">
                          {vehicle.plate}
                        </span>
                        <span class="text-on-surface-variant text-[12px]">
                          {kmLeft > 0
                            ? `Faltan ${kmLeft.toLocaleString()} km`
                            : `Excedido por ${Math.abs(kmLeft).toLocaleString()} km`}
                        </span>
                      </div>
                      <span
                        class={`material-symbols-outlined text-[18px] ${kmLeft <= 0 ? "text-error" : "text-on-surface-variant"}`}
                      >
                        {kmLeft <= 0 ? "notification_important" : "build"}
                      </span>
                    </div>
                  );
                })
            }
            {
              vehicles.filter((v) => v.nextRevisionKm && v.km).length === 0 && (
                <p class="text-on-surface-variant text-sm">
                  Sin revisiones programadas
                </p>
              )
            }
          </div>
        </div>

        <div
          class="glass-card border border-outline-variant rounded-xl p-md flex items-start justify-between hover:border-primary/50 transition-colors"
        >
          <div>
            <p
              class="text-label-md text-on-surface-variant uppercase tracking-widest mb-sm"
            >
              Gasto Total
            </p>
            <p
              class="text-headline-lg font-headline-lg text-on-surface font-data-mono"
            >
              {totalCost.toFixed(2)} €
            </p>
          </div>
          <div
            class={`w-10 h-10 rounded-lg bg-tertiary/10 flex items-center justify-center`}
          >
            <span class={`material-symbols-outlined text-tertiary`}
              >payments</span
            >
          </div>
        </div>

        <div class="glass-card rounded-xl p-md border border-outline-variant">
          <h5
            class="font-label-md text-label-md text-on-surface-variant uppercase mb-md"
          >
            Registrar Mantenimiento
          </h5>
          <a
            href={`/maintenance/new`}
            class="w-full text-left p-md bg-surface-container-high hover:bg-surface-variant transition-colors rounded-lg flex items-center justify-between group border border-outline-variant/30"
          >
            <div class="flex items-center gap-md">
              <span
                class="material-symbols-outlined text-tertiary"
                style="font-variation-settings: 'FILL' 1;">calendar_month</span
              >
              <span class="font-label-md">Nuevo</span>
            </div>
            <span
              class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform"
              >chevron_right</span
            >
          </a>
        </div>
      </div>

      <!-- Filters & Controls -->
      <div
        class="flex flex-col md:flex-row gap-md items-center justify-between bg-surface-container-low p-md rounded-xl border border-outline-variant"
      >
        <div class="flex flex-wrap gap-md items-center w-full md:w-auto">
          <div class="flex flex-col gap-xs">
            <label
              class="font-label-md text-label-md text-on-surface-variant ml-1"
              >Vehículo</label
            >
            <select
              class="bg-surface-container-highest border-none rounded-lg px-md py-sm text-on-surface font-body-md text-body-md focus:ring-1 focus:ring-primary min-w-[160px]"
            >
              <option>Todos los vehículos</option>
              {
                vehicles.map((v) => (
                  <option value={v.id}>
                    {v.plate} - {v.brand} {v.model}
                  </option>
                ))
              }
            </select>
          </div>
        </div>
      </div>

      <!-- Maintenance Data Table -->
      <div
        class="bg-surface-container rounded-xl border border-outline-variant overflow-hidden"
      >
        <table class="w-full text-left border-collapse">
          <thead>
            <tr
              class="bg-surface-container-high border-b border-outline-variant"
            >
              <th
                class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Fecha
              </th>
              <th
                class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Vehículo
              </th>
              <th
                class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Descripción
              </th>
              <th
                class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Tipo de Servicio
              </th>
              <th
                class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right"
              >
                Coste
              </th>
              <th class="px-lg py-md w-10"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant">
            {
              allMaintenances.length === 0 ? (
                <tr>
                  <td colspan="6" class="px-lg py-xl text-center">
                    <span class="material-symbols-outlined text-6xl text-outline/30 mb-md">
                      build
                    </span>
                    <h2 class="font-headline-md text-headline-md text-on-surface mb-sm">
                      No hay registros de mantenimiento
                    </h2>
                    <p class="text-body-lg text-on-surface-variant">
                      Añade tu primer registro de mantenimiento.
                    </p>
                  </td>
                </tr>
              ) : (
                allMaintenances.map((maintenance) => {
                  const vehicle = vehicles.find(
                    (v) => v.id === maintenance.vehicleId,
                  );
                  return (
                    <tr class="hover:bg-surface-container-highest transition-colors group">
                      <td class="px-lg py-md font-body-md text-body-md text-on-surface">
                        {maintenance.date
                          ? new Date(maintenance.date).toLocaleDateString(
                              "es-ES",
                            )
                          : "—"}
                      </td>
                      <td class="px-lg py-md">
                        <div class="flex items-center gap-md">
                          <span class="font-data-mono text-data-mono bg-surface-container-highest px-sm py-xs rounded border border-outline-variant">
                            {vehicle?.plate || "—"}
                          </span>
                          {maintenance.km && (
                            <span class="font-data-mono text-body-md text-on-surface-variant">
                              {maintenance.km.toLocaleString()} km
                            </span>
                          )}
                        </div>
                      </td>
                      <td class="px-lg py-md font-body-md text-body-md text-on-surface">
                        {maintenance.description || "—"}
                      </td>
                      <td class="px-lg py-md">
                        <span class="inline-flex items-center gap-1.5 px-md py-1 rounded-full bg-primary/10 text-primary font-label-md text-label-md">
                          <span class="material-symbols-outlined text-[14px]">
                            {typeIcons[maintenance.type] || "build"}
                          </span>
                          {MAINTENANCE_TYPE_LABELS[maintenance.type] ||
                            maintenance.type}
                        </span>
                      </td>
                      <td class="px-lg py-md font-data-mono text-data-mono text-right text-on-surface">
                        {maintenance.cost
                          ? `€${maintenance.cost.toFixed(2)}`
                          : "—"}
                      </td>
                      <td class="px-lg py-md text-right">
                        {vehicle && (
                          <div class="flex items-center justify-end gap-xs">
                            <a
                              href={`/maintenance/new?vehicleId=${vehicle.id}`}
                              class="p-2 hover:bg-surface-container-highest rounded-lg text-on-surface-variant hover:text-primary transition-colors opacity-0 group-hover:opacity-100"
                            >
                              <span class="material-symbols-outlined text-lg">
                                add
                              </span>
                            </a>
                          </div>
                        )}
                      </td>
                    </tr>
                  );
                })
              )
            }
          </tbody>
        </table>
        {
          allMaintenances.length > 0 && (
            <div class="px-lg py-md flex items-center justify-between bg-surface-container-low border-t border-outline-variant">
              <p class="font-label-md text-label-md text-on-surface-variant">
                Mostrando {allMaintenances.length} de {allMaintenances.length}{" "}
                registros
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</AppLayout>
