---
import AuthLayout from "../layouts/AuthLayout.astro";
import Button from "../components/ui/Button.astro";

if (Astro.locals.user) {
  return Astro.redirect("/vehicles");
}

let error = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = formData.get("email")?.toString();
  const password = formData.get("password")?.toString();

  if (email && password) {
    const { lucia } = await import("../lib/auth");
    const { db } = await import("../db/client");
    const { users } = await import("../db/schema");
    const { eq } = await import("drizzle-orm");
    const { verify } = await import("@node-rs/argon2");

    const [user] = await db
      .select()
      .from(users)
      .where(eq(users.email, email))
      .limit(1);

    if (user && (await verify(user.passwordHash, password))) {
      const session = await lucia.createSession(user.id, {});
      const sessionCookie = lucia.createSessionCookie(session.id);
      Astro.cookies.set(
        sessionCookie.name,
        sessionCookie.value,
        sessionCookie.attributes,
      );
      return Astro.redirect("/vehicles");
    } else {
      error = "Email o contraseña incorrectos";
    }
  }
}
---

<AuthLayout title="Iniciar sesión">
  <main class="flex-grow flex items-center justify-center p-gutter">
    <div class="w-full max-w-[400px] flex flex-col items-center">
      <!-- Branding Header -->
      <div class="mb-xl text-center flex items-center justify-center gap-1">
        <span
          class="material-symbols-outlined text-primary text-[32px]"
          style="font-variation-settings: 'FILL' 1;"
        >
          car_gear
        </span>

        <h1
          class="font-headline-lg text-headline-lg text-primary tracking-tight"
        >
          Vehicle Control
        </h1>
      </div>

      <!-- Login Container -->
      <div
        class="w-full p-xl rounded-xl border border-outline-variant/30 bg-surface-container-low/20 shadow-sm"
      >
        <header class="mb-lg">
          <h2 class="font-headline-sm text-headline-sm text-on-surface">
            Iniciar sesión
          </h2>
        </header>

        {
          error && (
            <div class="bg-error/10 border border-error/20 text-error px-md py-sm rounded-md mb-md text-body-md">
              {error}
            </div>
          )
        }

        <form method="POST" class="space-y-md" id="loginForm">
          <!-- Email Field -->
          <div class="space-y-xs">
            <label
              class="font-label-md text-label-md text-on-surface-variant ml-xs"
              for="email">EMAIL</label
            >
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors text-[20px]"
              >
                mail
              </span>
              <input
                class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg py-md pl-[44px] pr-md text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-0 transition-all font-body-md"
                id="email"
                name="email"
                placeholder="nombre@empresa.com"
                required
                type="email"
              />
            </div>
          </div>

          <!-- Password Field -->
          <div class="space-y-xs">
            <div class="flex justify-between items-center px-xs">
              <label
                class="font-label-md text-label-md text-on-surface-variant"
                for="password">CONTRASEÑA</label
              >
            </div>
            <div class="relative group">
              <span
                class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors text-[20px]"
              >
                lock
              </span>
              <input
                class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg py-md pl-[44px] pr-md text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-0 transition-all font-body-md"
                id="password"
                name="password"
                placeholder="••••••••"
                required
                type="password"
              />
            </div>
          </div>

          <!-- Sign In Button -->
          <Button
            type="submit"
            variant="primary"
            size="lg"
            class="w-full gap-1"
          >
            Entrar
            <span class="material-symbols-outlined">login</span>
          </Button>
        </form>

        <!-- Additional Actions -->
        <div
          class="mt-xl pt-lg border-t border-outline-variant/20 flex flex-col items-center"
        >
          <p class="font-body-md text-body-md text-on-surface-variant">
            ¿No tienes cuenta?
            <a
              class="text-primary font-bold hover:underline ml-xs"
              href="/register">Regístrate</a
            >
          </p>
        </div>
      </div>
    </div>
  </main>

  <script>
    document
      .getElementById("loginForm")
      ?.addEventListener("submit", function (e: any) {
        const btn = e.target.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement;
        const originalContent = btn.innerHTML;

        btn.disabled = true;
        btn.innerHTML = `
        <svg class="animate-spin h-5 w-5 text-on-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Autenticando...</span>
      `;

        setTimeout(() => {
          btn.innerHTML = originalContent;
          btn.disabled = false;
        }, 1500);
      });
  </script>
</AuthLayout>
