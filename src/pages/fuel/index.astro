---
import AppLayout from '@/layouts/AppLayout.astro';
import FuelSummaryCards from '@/components/fuel/FuelSummaryCards.astro';
import FuelFilters from '@/components/fuel/FuelFilters.astro';
import FuelTable from '@/components/fuel/FuelTable.astro';
import FuelForm from '@/components/fuel/FuelForm.astro';
import { getUserFuelLogs, createFuelLog, parseFuelFormData, calculateFuelStats } from '@/lib/fuel-service';
import { getUserVehicles } from '@/lib/vehicle-service';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const vehicleFilter = Astro.url.searchParams.get('vehicle');
const showForm = Astro.url.searchParams.get('new') === 'true';

if (Astro.request.method === 'POST') {
  const data = await parseFuelFormData(await Astro.request.formData());
  if (data.vehicleId && data.liters && data.pricePerLiter && data.total) {
    await createFuelLog(data);
    return Astro.redirect(vehicleFilter ? `/fuel?vehicle=${vehicleFilter}` : '/fuel');
  }
}

const [userVehicles, userFuelLogs] = await Promise.all([
  getUserVehicles(Astro.locals.user.id),
  getUserFuelLogs(Astro.locals.user.id, vehicleFilter ?? undefined),
]);

const vehicleMap = new Map(userVehicles.map((v) => [v.id, { name: `${v.brand} ${v.model}`, plate: v.plate, brand: v.brand }]));
const stats = calculateFuelStats(userFuelLogs);
const ctaHref = vehicleFilter ? `/fuel?vehicle=${vehicleFilter}&new=true` : '/fuel?new=true';
---

<AppLayout title="Combustible">
  <div class="space-y-lg">
    <FuelSummaryCards
      totalCost={stats.totalCost}
      avgConsumption={stats.avgConsumption}
      ctaHref={ctaHref}
      costTrend={null}
      consumptionTrend={null}
      refuelCount={stats.totalRefuels}
      avgPricePerLiter={stats.avgPricePerLiter}
      totalLiters={stats.totalLiters}
    />

    <FuelFilters
      vehicles={userVehicles}
      selectedVehicleId={vehicleFilter}
    />

    <FuelTable
      fuelLogs={userFuelLogs}
      vehicleMap={vehicleMap}
    />
  </div>
</AppLayout>
