---
import AppLayout from '@/layouts/AppLayout.astro';
import FuelSummaryCards from '@/components/fuel/FuelSummaryCards.astro';
import FuelFilters from '@/components/fuel/FuelFilters.astro';
import FuelTable from '@/components/fuel/FuelTable.astro';
import FuelForm from '@/components/fuel/FuelForm.astro';
import { db } from '@/db/client';
import { vehicles, fuelLogs } from '@/db/schema';
import { eq, and, desc, inArray } from 'drizzle-orm';
import { createId } from '@paralleldrive/cuid2';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const vehicleFilter = Astro.url.searchParams.get('vehicle');
const showForm = Astro.url.searchParams.get('new') === 'true';

const userVehicles = await db
  .select()
  .from(vehicles)
  .where(eq(vehicles.userId, Astro.locals.user.id));

const vehicleIds = userVehicles.map((v) => v.id);

let userFuelLogs;
if (vehicleFilter && vehicleIds.includes(vehicleFilter)) {
  userFuelLogs = await db
    .select()
    .from(fuelLogs)
    .where(eq(fuelLogs.vehicleId, vehicleFilter))
    .orderBy(desc(fuelLogs.date));
} else if (vehicleIds.length > 0) {
  userFuelLogs = await db
    .select()
    .from(fuelLogs)
    .where(inArray(fuelLogs.vehicleId, vehicleIds))
    .orderBy(desc(fuelLogs.date));
} else {
  userFuelLogs = [];
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const vehicleId = formData.get('vehicleId')?.toString();
  const date = formData.get('date')?.toString();
  const liters = formData.get('liters')?.toString();
  const pricePerLiter = formData.get('pricePerLiter')?.toString();
  const total = formData.get('total')?.toString();
  const km = formData.get('km')?.toString();

  if (vehicleId && liters && pricePerLiter && total) {
    await db.insert(fuelLogs).values({
      id: createId(),
      vehicleId,
      date: date ? new Date(date).getTime() : Date.now(),
      liters: parseFloat(liters),
      pricePerLiter: parseFloat(pricePerLiter),
      total: parseFloat(total),
      km: km ? parseInt(km) : null,
    });

    if (km) {
      await db.update(vehicles).set({ km: parseInt(km) }).where(eq(vehicles.id, vehicleId));
    }

    return Astro.redirect(vehicleFilter ? `/fuel?vehicle=${vehicleFilter}` : '/fuel');
  }
}

const vehicleMap = new Map(userVehicles.map((v) => [v.id, { name: `${v.brand} ${v.model}`, plate: v.plate, brand: v.brand }]));

function calculateStats(logs: typeof userFuelLogs) {
  if (logs.length === 0) return { totalCost: 0, avgConsumption: 0 };
  const totalCost = logs.reduce((sum, f) => sum + f.total, 0);
  const sorted = [...logs].filter((f) => f.km !== null && f.date !== null).sort((a, b) => (a.date || 0) - (b.date || 0));
  let totalKm = 0;
  let litersForConsumption = 0;
  for (let i = 1; i < sorted.length; i++) {
    if (sorted[i - 1].km && sorted[i].km) {
      const diff = sorted[i].km! - sorted[i - 1].km!;
      if (diff > 0) { totalKm += diff; litersForConsumption += sorted[i].liters; }
    }
  }
  return {
    totalCost,
    avgConsumption: totalKm > 0 ? (litersForConsumption / totalKm) * 100 : 0,
  };
}

const stats = calculateStats(userFuelLogs);
const ctaHref = vehicleFilter ? `/fuel?vehicle=${vehicleFilter}&new=true` : '/fuel?new=true';
---

<AppLayout title="Combustible">
  <div class="space-y-lg">
    <FuelSummaryCards
      totalCost={stats.totalCost}
      avgConsumption={stats.avgConsumption}
      ctaHref={ctaHref}
    />

    {showForm && (
      <div class="bg-surface-container border border-outline-variant rounded-xl p-lg">
        <h2 class="text-headline-sm text-on-surface mb-md">Nueva carga</h2>
        {vehicleFilter ? (
          <FuelForm
            vehicleId={vehicleFilter}
            action={`/fuel?vehicle=${vehicleFilter}`}
          />
        ) : (
          <div class="space-y-md">
            <p class="text-body-md text-on-surface-variant">Selecciona un vehículo:</p>
            <div class="grid gap-sm">
              {userVehicles.map((v) => (
                <a
                  href={`/fuel?vehicle=${v.id}&new=true`}
                  class="p-md bg-surface-container-high hover:bg-surface-variant transition-colors rounded-lg flex items-center justify-between group border border-outline-variant/30"
                >
                  <div class="flex items-center gap-md">
                    <span class="material-symbols-outlined text-primary">directions_car</span>
                    <span class="font-label-md">{v.brand} {v.model}</span>
                    <span class="font-data-mono text-primary">{v.plate}</span>
                  </div>
                  <span class="material-symbols-outlined text-outline group-hover:translate-x-1 transition-transform">chevron_right</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    <FuelFilters
      vehicles={userVehicles}
      selectedVehicleId={vehicleFilter}
    />

    <FuelTable
      fuelLogs={userFuelLogs}
      vehicleMap={vehicleMap}
    />
  </div>
</AppLayout>
