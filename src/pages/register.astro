---
import AppLayout from '../layouts/AppLayout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';

if (Astro.locals.user) {
  return Astro.redirect('/vehicles');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString();
  const password = formData.get('password')?.toString();
  const name = formData.get('name')?.toString();

  if (email && password) {
    const { lucia } = await import('../lib/auth');
    const { db } = await import('../db/client');
    const { users } = await import('../db/schema');
    const { eq } = await import('drizzle-orm');
    const { hash } = await import('@node-rs/argon2');
    const { createId } = await import('@paralleldrive/cuid2');

    const existingUser = await db.select().from(users).where(eq(users.email, email)).limit(1);

    if (existingUser.length > 0) {
      error = 'Este email ya está registrado';
    } else {
      const passwordHash = await hash(password);
      const userId = createId();

      await db.insert(users).values({
        id: userId,
        email,
        passwordHash,
        name,
        createdAt: Date.now(),
      });

      const session = await lucia.createSession(userId, {});
      const sessionCookie = lucia.createSessionCookie(session.id);
      Astro.cookies.set(sessionCookie.name, sessionCookie.value, sessionCookie.attributes);
      return Astro.redirect('/vehicles');
    }
  }
}
---

<AppLayout title="Registro">
  <div class="min-h-[80vh] flex items-center justify-center">
    <div class="w-full max-w-md">
      <Card>
        <div class="text-center mb-lg">
          <div class="w-12 h-12 bg-primary/20 rounded-lg flex items-center justify-center mx-auto mb-md">
            <span class="text-2xl">🚗</span>
          </div>
          <h1 class="text-headline-md text-on-surface">Crear cuenta</h1>
          <p class="text-body-md text-on-surface-variant mt-xs">Regístrate para empezar a gestionar tus vehículos</p>
        </div>

        {error && (
          <div class="bg-error/10 border border-error/20 text-error px-md py-sm rounded-md mb-md text-body-md">
            {error}
          </div>
        )}

        <form method="POST" class="space-y-md">
          <div>
            <label for="name" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
              Nombre
            </label>
            <input
              type="text"
              id="name"
              name="name"
              class="input-base"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label for="email" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="input-base"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label for="password" class="block text-label-md text-on-surface-variant uppercase tracking-wider mb-xs">
              Contraseña
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="6"
              class="input-base"
              placeholder="••••••••"
            />
          </div>

          <Button type="submit" variant="primary" size="lg" class="w-full">
            Registrarse
          </Button>
        </form>

        <p class="mt-lg text-center text-body-md text-on-surface-variant">
          ¿Ya tienes cuenta?{' '}
          <a href="/login" class="text-primary hover:text-primary/80 font-medium transition-colors">
            Inicia sesión
          </a>
        </p>
      </Card>
    </div>
  </div>
</AppLayout>
