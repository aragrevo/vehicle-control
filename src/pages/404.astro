---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Página no encontrada" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>404 | Vehicle Control</title>
  </head>
  <body
    class="bg-background text-on-background font-body-md h-screen max-h-screen overflow-hidden"
  >
    <!-- Main Content (404 Page) -->
    <main
      class="flex-1 relative flex items-center justify-center p-md bg-grid-pattern"
    >
      <div class="max-w-2xl w-full text-center z-10">
        <!-- 404 Visual Signal -->
        <div class="relative inline-block mb-xl">
          <div
            class="absolute inset-0 blur-3xl bg-primary/20 rounded-full scale-150 animate-pulse"
          >
          </div>
          <div class="relative flex flex-col items-center">
            <div class="flex items-center justify-center mb-md">
              <span
                class="text-[120px] md:text-[180px] font-headline-lg text-primary/10 tracking-tighter leading-none select-none"
                >404</span
              >
            </div>
            <div class="h-1 w-24 bg-primary/30 rounded-full blur-sm"></div>
          </div>
        </div>
        <!-- Messaging -->
        <div class="space-y-md">
          <h1 class="font-headline-lg text-headline-lg text-on-surface">
            Vehículo fuera de ruta
          </h1>
          <p
            class="font-body-lg text-body-lg text-on-surface-variant max-w-md mx-auto"
          >
            Parece que te has desviado del camino. La página que buscas no
            existe o ha sido movida del sistema de control.
          </p>
        </div>
        <!-- Action Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-md mt-xl">
          <a
            class="group flex flex-col items-center p-lg bg-surface-container-high border border-outline-variant rounded-xl hover:border-primary transition-all duration-300 glow-effect"
            href="/"
          >
            <div
              class="p-sm bg-primary/10 rounded-lg group-hover:bg-primary/20 transition-colors mb-md"
            >
              <span class="material-symbols-outlined text-primary"
                >dashboard</span
              >
            </div>
            <span class="font-headline-sm text-headline-sm text-on-surface"
              >Volver al Dashboard</span
            >
            <p class="text-label-md font-label-md text-outline mt-xs">
              Regresar al panel principal
            </p>
          </a>
          <a
            class="group flex flex-col items-center p-lg bg-surface-container-high border border-outline-variant rounded-xl hover:border-primary transition-all duration-300 glow-effect"
            href="/"
          >
            <div
              class="p-sm bg-secondary-container/30 rounded-lg group-hover:bg-secondary-container transition-colors mb-md"
            >
              <span class="material-symbols-outlined text-secondary"
                >local_shipping</span
              >
            </div>
            <span class="font-headline-sm text-headline-sm text-on-surface"
              >Ver Mis Vehículos</span
            >
            <p class="text-label-md font-label-md text-outline mt-xs">
              Monitorear flota activa
            </p>
          </a>
        </div>
      </div>
      <!-- Decorative background elements -->
      <div
        class="absolute bottom-0 right-0 w-1/3 h-1/3 opacity-10 pointer-events-none translate-x-1/4 translate-y-1/4"
      >
        <span class="material-symbols-outlined text-[300px] text-primary"
          >navigation</span
        >
      </div>
      <div
        class="absolute top-1/4 left-1/4 w-12 h-12 bg-primary/20 rounded-full blur-xl animate-pulse"
      >
      </div>
      <div
        class="absolute bottom-1/4 right-1/4 w-8 h-8 bg-error/20 rounded-full blur-lg animate-ping"
      >
      </div>
    </main>

    <script>
      document.addEventListener("mousemove", (e) => {
        const glow = document.getElementById("glow");
        if (glow) {
          const moveX = (e.clientX - window.innerWidth / 2) / 40;
          const moveY = (e.clientY - window.innerHeight / 2) / 40;
          glow.style.transform = `scale(1.5) translate(${moveX}px, ${moveY}px)`;
        }
      });
    </script>
  </body>
</html>

<style>
  .material-symbols-outlined {
    font-variation-settings:
      "FILL" 0,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
  }
  body {
    background-color: #10131a;
    color: #e1e2ec;
    overflow-x: hidden;
  }
  .bg-grid-pattern {
    background-image: radial-gradient(#32353c 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .glow-effect {
    box-shadow: 0 0 40px -10px rgba(173, 198, 255, 0.2);
  }
</style>
