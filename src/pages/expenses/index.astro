---
import AppLayout from '@/layouts/AppLayout.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import ExpensesSummary from '@/components/fuel/ExpensesSummary.astro';
import { getUserExpenses } from '@/lib/expense-service';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const vehicleFilter = Astro.url.searchParams.get('vehicle');
const { vehicles: userVehicles, maintenances: userMaintenances, fuelLogs: userFuelLogs } = await getUserExpenses(Astro.locals.user.id, vehicleFilter ?? undefined);

const vehicleMap = new Map(userVehicles.map((v) => [v.id, `${v.brand} ${v.model}`]));
const selectedVehicle = vehicleFilter ? userVehicles.find((v) => v.id === vehicleFilter) : null;
---

<AppLayout title="Gastos">
  <div class="space-y-lg">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-headline-lg text-on-surface">Gastos</h1>
        <p class="text-body-lg text-on-surface-variant mt-xs">
          {vehicleFilter
            ? `Gastos de ${vehicleMap.get(vehicleFilter) || 'vehículo'}`
            : 'Resumen de gastos de tu flota'}
        </p>
      </div>
      <div class="flex items-center gap-sm">
        {vehicleFilter && (
          <Button href="/expenses" variant="secondary">
            Ver todos
          </Button>
        )}
      </div>
    </div>

    {userVehicles.length > 0 && (
      <Card>
        <h2 class="text-headline-sm text-on-surface mb-md">Filtrar por vehículo</h2>
        <div class="flex flex-wrap gap-sm">
          <Button
            href="/expenses"
            variant={!vehicleFilter ? 'primary' : 'ghost'}
            size="sm"
          >
            Todos
          </Button>
          {userVehicles.map((v) => (
            <Button
              href={`/expenses?vehicle=${v.id}`}
              variant={vehicleFilter === v.id ? 'primary' : 'ghost'}
              size="sm"
            >
              {v.brand} {v.model}
            </Button>
          ))}
        </div>
      </Card>
    )}

    <Card>
      <ExpensesSummary
        maintenances={userMaintenances}
        fuelLogs={userFuelLogs}
        vehicleName={selectedVehicle ? `${selectedVehicle.brand} ${selectedVehicle.model}` : undefined}
      />
    </Card>
  </div>
</AppLayout>
