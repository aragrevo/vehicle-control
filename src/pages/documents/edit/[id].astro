---
import AppLayout from '@/layouts/AppLayout.astro';
import Card from '@/components/ui/Card.astro';
import DocumentForm from '@/components/documents/DocumentForm.astro';
import { db } from '@/db/client';
import { documents, vehicles } from '@/db/schema';
import { eq, and } from 'drizzle-orm';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/documents');
}

const [document] = await db
  .select()
  .from(documents)
  .where(eq(documents.id, id))
  .limit(1);

if (!document) {
  return Astro.redirect('/documents');
}

const [vehicle] = await db
  .select()
  .from(vehicles)
  .where(and(eq(vehicles.id, document.vehicleId), eq(vehicles.userId, Astro.locals.user.id)))
  .limit(1);

if (!vehicle) {
  return Astro.redirect('/documents');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const type = formData.get('type')?.toString();
  const expiresAt = formData.get('expiresAt')?.toString();
  const alertDaysBefore = formData.get('alertDaysBefore')?.toString();
  const fileUrl = formData.get('fileUrl')?.toString() || null;

  if (type) {
    await db
      .update(documents)
      .set({
        type,
        expiresAt: expiresAt ? new Date(expiresAt).getTime() : null,
        alertDaysBefore: alertDaysBefore ? parseInt(alertDaysBefore) : 30,
        fileUrl,
      })
      .where(eq(documents.id, id));

    return Astro.redirect(`/documents?vehicle=${document.vehicleId}`);
  }
}
---

<AppLayout title="Editar documento">
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href={`/documents?vehicle=${document.vehicleId}`} class="text-gray-500 hover:text-gray-700">
        ← Volver
      </a>
      <h1 class="text-2xl font-bold text-gray-900 mt-2">Editar documento</h1>
      <p class="text-gray-500">
        {vehicle.brand} {vehicle.model} ({vehicle.plate})
      </p>
    </div>

    <Card>
      <DocumentForm
        vehicleId={document.vehicleId}
        document={document}
        action={`/documents/edit/${id}`}
      />
    </Card>
  </div>
</AppLayout>
