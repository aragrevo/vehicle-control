---
import AppLayout from '../../layouts/AppLayout.astro';
import VehicleCard from '../../components/vehicles/VehicleCard.astro';
import Button from '../../components/ui/Button.astro';
import { db } from '../../db/client';
import { vehicles } from '../../db/schema';
import { eq } from 'drizzle-orm';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const userVehicles = await db
  .select()
  .from(vehicles)
  .where(eq(vehicles.userId, Astro.locals.user.id))
  .orderBy(vehicles.createdAt);
---

<AppLayout title="Vehículos">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Mis vehículos</h1>
        <p class="text-gray-500 mt-1">
          {userVehicles.length} vehículo{userVehicles.length !== 1 ? 's' : ''} registrado{userVehicles.length !== 1 ? 's' : ''}
        </p>
      </div>
      <Button href="/vehicles/new" variant="primary">
        + Nuevo vehículo
      </Button>
    </div>

    {userVehicles.length === 0 ? (
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
        <div class="text-6xl mb-4">🚗</div>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">
          No tienes vehículos registrados
        </h2>
        <p class="text-gray-500 mb-6">
          Añade tu primer vehículo para empezar a gestionar su mantenimiento y documentos.
        </p>
        <Button href="/vehicles/new" variant="primary">
          Añadir vehículo
        </Button>
      </div>
    ) : (
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {userVehicles.map((vehicle) => (
          <VehicleCard
            id={vehicle.id}
            plate={vehicle.plate}
            brand={vehicle.brand}
            model={vehicle.model}
            year={vehicle.year}
            km={vehicle.km}
            status={vehicle.status}
          />
        ))}
      </div>
    )}
  </div>
</AppLayout>
