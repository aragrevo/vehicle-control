            <p class="text-[10px] text-outline">Tipo de combustible</p>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-container p-md rounded-xl border border-outline-variant"
      >
        <div class="flex justify-between mb-sm">
          <p class="text-label-md text-outline uppercase">Próxima Revisión</p>
