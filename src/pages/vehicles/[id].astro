      >
        <p class="text-label-md text-outline mb-sm uppercase">Odómetro</p>
        <div class="flex items-end justify-between">
          <h4
            class="font-headline-md text-headline-md text-primary font-data-mono"
          >
            {vehicle.km !== null ? vehicle.km.toLocaleString() : "0"}
            <span class="text-label-md text-outline">KM</span>
          </h4>
        </div>
      </div>

      <div
        class="bg-surface-container p-md rounded-xl border border-outline-variant"
      >
        <p class="text-label-md text-outline mb-sm uppercase">Combustible</p>
        <div class="flex items-center gap-md">
          <span
            class="material-symbols-outlined text-primary"
            style="font-size: 32px;"
          >
            {
              vehicle.fuelType === "electric"
                ? "ev_station"
                : vehicle.fuelType === "diesel"
                  ? "local_gas_station"
                  : "local_gas_station"
