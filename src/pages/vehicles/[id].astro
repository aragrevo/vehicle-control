<span class="material-symbols-outlined text-error">report_problem</span>
<div class="flex-1">
<p class="text-label-md text-error font-bold">1 Critical Alert</p>
<p class="text-[10px] text-error/80">Tire pressure low - Front Left</p>
</div>
</div>
            <a
