---
import AppLayout from '../../layouts/AppLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import { db } from '../../db/client';
import { vehicles, maintenances, documents } from '../../db/schema';
import { eq, and, desc } from 'drizzle-orm';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/vehicles');
}

const [vehicle] = await db
  .select()
  .from(vehicles)
  .where(and(eq(vehicles.id, id), eq(vehicles.userId, Astro.locals.user.id)))
  .limit(1);

if (!vehicle) {
  return Astro.redirect('/vehicles');
}

const vehicleMaintenances = await db
  .select()
  .from(maintenances)
  .where(eq(maintenances.vehicleId, id))
  .orderBy(desc(maintenances.date))
  .limit(5);

const vehicleDocuments = await db
  .select()
  .from(documents)
  .where(eq(documents.vehicleId, id));

const maintenanceTypes: Record<string, string> = {
  oil_change: 'Cambio de aceite',
  tires: 'Neumáticos',
  brakes: 'Frenos',
  revision: 'Revisión',
  other: 'Otro',
};

const documentTypes: Record<string, string> = {
  itv: 'ITV',
  insurance: 'Seguro',
  registration: 'Permiso de circulación',
};

function getDocumentStatus(expiresAt: number | null, alertDaysBefore: number) {
  if (!expiresAt) return 'unknown';
  const now = Date.now();
  const diffDays = Math.ceil((expiresAt - now) / (1000 * 60 * 60 * 24));
  if (diffDays < 0) return 'expired';
  if (diffDays <= alertDaysBefore) return 'expiring';
  return 'valid';
}

const statusVariants = {
  valid: 'success',
  expiring: 'warning',
  expired: 'danger',
  unknown: 'gray',
} as const;
---

<AppLayout title={`${vehicle.brand} ${vehicle.model}`}>
  <div class="space-y-6">
    {/* Header */}
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl font-bold text-gray-900">
            {vehicle.brand} {vehicle.model}
          </h1>
          <Badge variant={vehicle.status === 'active' ? 'success' : 'gray'}>
            {vehicle.status === 'active' ? 'Activo' : 'Inactivo'}
          </Badge>
        </div>
        <p class="text-gray-500 font-mono">{vehicle.plate}</p>
      </div>
      <div class="flex items-center gap-3">
        <Button href={`/vehicles/${id}/edit`} variant="secondary">
          Editar
        </Button>
        <form method="POST" action={`/api/vehicles/${id}/toggle-status`}>
          <Button type="submit" variant="ghost">
            {vehicle.status === 'active' ? 'Desactivar' : 'Activar'}
          </Button>
        </form>
      </div>
    </div>

    {/* Vehicle info */}
    <div class="grid gap-6 md:grid-cols-2">
      <Card>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Información general</h2>
        <dl class="space-y-3">
          {vehicle.vin && (
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">VIN</dt>
              <dd class="text-sm font-medium text-gray-900 font-mono">{vehicle.vin}</dd>
            </div>
          )}
          {vehicle.year && (
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">Año</dt>
              <dd class="text-sm font-medium text-gray-900">{vehicle.year}</dd>
            </div>
          )}
          {vehicle.color && (
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">Color</dt>
              <dd class="text-sm font-medium text-gray-900">{vehicle.color}</dd>
            </div>
          )}
          {vehicle.fuelType && (
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">Combustible</dt>
              <dd class="text-sm font-medium text-gray-900 capitalize">{vehicle.fuelType}</dd>
            </div>
          )}
          {vehicle.km !== null && (
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">Kilometraje</dt>
              <dd class="text-sm font-medium text-gray-900">
                {vehicle.km.toLocaleString()} km
              </dd>
            </div>
          )}
        </dl>
      </Card>

      <Card>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Documentos</h2>
        {vehicleDocuments.length === 0 ? (
          <p class="text-sm text-gray-500">No hay documentos registrados</p>
        ) : (
          <div class="space-y-3">
            {vehicleDocuments.map((doc) => {
              const status = getDocumentStatus(doc.expiresAt, doc.alertDaysBefore ?? 30);
              return (
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-900">
                      {documentTypes[doc.type] || doc.type}
                    </p>
                    {doc.expiresAt && (
                      <p class="text-xs text-gray-500">
                        Vence: {new Date(doc.expiresAt).toLocaleDateString('es-ES')}
                      </p>
                    )}
                  </div>
                  <Badge variant={statusVariants[status]}>
                    {status === 'valid' ? 'Vigente' : status === 'expiring' ? 'Vence pronto' : status === 'expired' ? 'Caducado' : 'Sin fecha'}
                  </Badge>
                </div>
              );
            })}
          </div>
        )}
        <div class="mt-4">
          <Button href={`/documents?vehicle=${id}`} variant="ghost" size="sm">
            Gestionar documentos
          </Button>
        </div>
      </Card>
    </div>

    {/* Recent maintenance */}
    <Card>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Últimos mantenimientos</h2>
        <Button href={`/maintenance/${id}`} variant="ghost" size="sm">
          Ver todos
        </Button>
      </div>

      {vehicleMaintenances.length === 0 ? (
        <p class="text-sm text-gray-500">No hay mantenimientos registrados</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Tipo</th>
                <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Fecha</th>
                <th class="text-left text-xs font-medium text-gray-500 uppercase pb-3">Km</th>
                <th class="text-right text-xs font-medium text-gray-500 uppercase pb-3">Coste</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {vehicleMaintenances.map((m) => (
                <tr>
                  <td class="py-3 text-sm text-gray-900">
                    {maintenanceTypes[m.type] || m.type}
                  </td>
                  <td class="py-3 text-sm text-gray-500">
                    {m.date ? new Date(m.date).toLocaleDateString('es-ES') : '-'}
                  </td>
                  <td class="py-3 text-sm text-gray-500">
                    {m.km?.toLocaleString() || '-'}
                  </td>
                  <td class="py-3 text-sm text-gray-900 text-right">
                    {m.cost ? `${m.cost.toFixed(2)} €` : '-'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </Card>

    {/* Quick actions */}
    <div class="flex items-center gap-4">
      <Button href={`/maintenance/${id}?new=true`} variant="secondary">
        + Añadir mantenimiento
      </Button>
      <Button href={`/fuel/${id}?new=true`} variant="secondary">
        + Registrar repostaje
      </Button>
    </div>
  </div>
</AppLayout>
