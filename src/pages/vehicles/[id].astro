---
import AppLayout from "@/layouts/AppLayout.astro";
import HeroCarousel from "@/components/vehicles/detail/HeroCarousel.astro";
import QuickActions from "@/components/vehicles/detail/QuickActions.astro";
import VehicleKPIs from "@/components/vehicles/detail/VehicleKPIs.astro";
import FuelChart from "@/components/vehicles/detail/FuelChart.astro";
import StatusGauges from "@/components/vehicles/detail/StatusGauges.astro";
import ActivityLog from "@/components/vehicles/detail/ActivityLog.astro";
import { getVehicleDashboardData } from "@/lib/vehicle-dashboard";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/vehicles");
}

const data = await getVehicleDashboardData(id, Astro.locals.user.id);
if (!data) {
  return Astro.redirect("/vehicles");
}

const {
  vehicle, vehiclePhotos, vehicleFuelLogs, vehicleMaintenances,
  chartData, efficiency, activityItems,
  itvStatus, itvDays, revisionProgress, revisionRemaining, gauges, fuelTypeLabel,
} = data;
---

<AppLayout title={`${vehicle.brand} ${vehicle.model}`}>
  <div class="space-y-lg">
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
      <HeroCarousel
        photos={vehiclePhotos}
        brand={vehicle.brand}
        model={vehicle.model}
        plate={vehicle.plate}
        status={vehicle.status}
        fuelType={vehicle.fuelType}
        year={vehicle.year}
        color={vehicle.color}
        fuelTypeLabel={fuelTypeLabel}
      />
      <QuickActions
        vehicleId={id}
        itvStatus={itvStatus}
        itvDays={itvDays}
      />
    </section>

    <VehicleKPIs
      km={vehicle.km}
      fuelType={vehicle.fuelType}
      fuelTypeLabel={fuelTypeLabel}
      revisionProgress={revisionProgress}
      revisionRemaining={revisionRemaining}
      nextRevisionKm={vehicle.nextRevisionKm}
      vin={vehicle.vin}
      plate={vehicle.plate}
      color={vehicle.color}
      year={vehicle.year}
    />

    <section class="grid grid-cols-1 xl:grid-cols-12 gap-lg">
      <FuelChart
        days={chartData.days}
        dailyLiters={chartData.dailyLiters}
        dailyCost={chartData.dailyCost}
        maxLiters={chartData.maxLiters}
        efficiencyData={efficiency.data}
        maxEfficiency={efficiency.maxEfficiency}
        avgEfficiency={efficiency.avgEfficiency}
      />
      <StatusGauges gauges={gauges} />
    </section>

    <ActivityLog items={activityItems} vehicleId={id} />
  </div>
</AppLayout>
