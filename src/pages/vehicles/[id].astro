---
import AppLayout from '../../layouts/AppLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import { db } from '../../db/client';
import { vehicles, maintenances, documents } from '../../db/schema';
import { eq, and, desc } from 'drizzle-orm';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/vehicles');
}

const [vehicle] = await db
  .select()
  .from(vehicles)
  .where(and(eq(vehicles.id, id), eq(vehicles.userId, Astro.locals.user.id)))
  .limit(1);

if (!vehicle) {
  return Astro.redirect('/vehicles');
}

const vehicleMaintenances = await db
  .select()
  .from(maintenances)
  .where(eq(maintenances.vehicleId, id))
  .orderBy(desc(maintenances.date))
  .limit(5);

const vehicleDocuments = await db
  .select()
  .from(documents)
  .where(eq(documents.vehicleId, id));

const maintenanceTypes: Record<string, string> = {
  oil_change: 'Cambio de aceite',
  tires: 'Neumáticos',
  brakes: 'Frenos',
  revision: 'Revisión',
  other: 'Otro',
};

const documentTypes: Record<string, string> = {
  itv: 'ITV',
  insurance: 'Seguro',
  registration: 'Permiso de circulación',
};

function getDocumentStatus(expiresAt: number | null, alertDaysBefore: number) {
  if (!expiresAt) return 'unknown';
  const now = Date.now();
  const diffDays = Math.ceil((expiresAt - now) / (1000 * 60 * 60 * 24));
  if (diffDays < 0) return 'expired';
  if (diffDays <= alertDaysBefore) return 'expiring';
  return 'valid';
}

const statusVariants = {
  valid: 'success',
  expiring: 'warning',
  expired: 'danger',
  unknown: 'neutral',
} as const;

const statusLabels = {
  valid: 'Vigente',
  expiring: 'Vence pronto',
  expired: 'Caducado',
  unknown: 'Sin fecha',
};

const statusIcons = {
  valid: '✓',
  expiring: '⚠',
  expired: '✕',
  unknown: '?',
};
---

<AppLayout title={`${vehicle.brand} ${vehicle.model}`}>
  <div class="space-y-lg">
    {/* Header */}
    <div class="flex items-start justify-between">
      <div>
        <a href="/vehicles" class="text-body-md text-on-surface-variant hover:text-primary transition-colors">
          ← Volver a vehículos
        </a>
        <div class="flex items-center gap-md mt-sm">
          <h1 class="text-headline-lg text-on-surface">
            {vehicle.brand} {vehicle.model}
          </h1>
          <Badge
            variant={vehicle.status === 'active' ? 'success' : 'neutral'}
            icon={vehicle.status === 'active' ? '✓' : '○'}
          >
            {vehicle.status === 'active' ? 'Activo' : 'Inactivo'}
          </Badge>
        </div>
        <div class="inline-block px-sm py-xs bg-surface-container-highest rounded-md mt-sm">
          <span class="font-mono text-data-mono text-primary tracking-wider">{vehicle.plate}</span>
        </div>
      </div>
      <div class="flex items-center gap-sm">
        <Button href={`/vehicles/${id}/edit`} variant="secondary">
          Editar
        </Button>
        <form method="POST" action={`/api/vehicles/${id}/toggle-status`}>
          <Button type="submit" variant="ghost">
            {vehicle.status === 'active' ? 'Desactivar' : 'Activar'}
          </Button>
        </form>
      </div>
    </div>

    {/* Vehicle info */}
    <div class="grid gap-md md:grid-cols-2">
      <Card>
        <h2 class="text-headline-sm text-on-surface mb-md">Información general</h2>
        <dl class="space-y-sm">
          {vehicle.vin && (
            <div class="flex justify-between items-center py-xs border-b border-outline-variant">
              <dt class="text-label-md text-on-surface-variant uppercase">VIN</dt>
              <dd class="font-mono text-data-mono text-on-surface">{vehicle.vin}</dd>
            </div>
          )}
          {vehicle.year && (
            <div class="flex justify-between items-center py-xs border-b border-outline-variant">
              <dt class="text-label-md text-on-surface-variant uppercase">Año</dt>
              <dd class="text-body-md text-on-surface font-medium">{vehicle.year}</dd>
            </div>
          )}
          {vehicle.color && (
            <div class="flex justify-between items-center py-xs border-b border-outline-variant">
              <dt class="text-label-md text-on-surface-variant uppercase">Color</dt>
              <dd class="text-body-md text-on-surface font-medium">{vehicle.color}</dd>
            </div>
          )}
          {vehicle.fuelType && (
            <div class="flex justify-between items-center py-xs border-b border-outline-variant">
              <dt class="text-label-md text-on-surface-variant uppercase">Combustible</dt>
              <dd class="text-body-md text-on-surface font-medium capitalize">{vehicle.fuelType}</dd>
            </div>
          )}
          {vehicle.km !== null && (
            <div class="flex justify-between items-center py-xs">
              <dt class="text-label-md text-on-surface-variant uppercase">Kilometraje</dt>
              <dd class="font-mono text-data-mono text-on-surface">{vehicle.km.toLocaleString()} km</dd>
            </div>
          )}
        </dl>
      </Card>

      <Card>
        <h2 class="text-headline-sm text-on-surface mb-md">Documentos</h2>
        {vehicleDocuments.length === 0 ? (
          <p class="text-body-md text-on-surface-variant">No hay documentos registrados</p>
        ) : (
          <div class="space-y-sm">
            {vehicleDocuments.map((doc) => {
              const status = getDocumentStatus(doc.expiresAt, doc.alertDaysBefore ?? 30);
              return (
                <div class="flex items-center justify-between py-xs border-b border-outline-variant last:border-0">
                  <div>
                    <p class="text-body-md text-on-surface font-medium">
                      {documentTypes[doc.type] || doc.type}
                    </p>
                    {doc.expiresAt && (
                      <p class="text-label-md text-on-surface-variant">
                        Vence: {new Date(doc.expiresAt).toLocaleDateString('es-ES')}
                      </p>
                    )}
                  </div>
                  <Badge variant={statusVariants[status]} icon={statusIcons[status]}>
                    {statusLabels[status]}
                  </Badge>
                </div>
              );
            })}
          </div>
        )}
        <div class="mt-md">
          <Button href={`/documents?vehicle=${id}`} variant="ghost" size="sm">
            Gestionar documentos →
          </Button>
        </div>
      </Card>
    </div>

    {/* Recent maintenance */}
    <Card>
      <div class="flex items-center justify-between mb-md">
        <h2 class="text-headline-sm text-on-surface">Últimos mantenimientos</h2>
        <Button href={`/maintenance/${id}`} variant="ghost" size="sm">
          Ver todos →
        </Button>
      </div>

      {vehicleMaintenances.length === 0 ? (
        <p class="text-body-md text-on-surface-variant">No hay mantenimientos registrados</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-outline-variant">
                <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Tipo</th>
                <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Fecha</th>
                <th class="text-left text-label-md text-on-surface-variant uppercase pb-sm">Km</th>
                <th class="text-right text-label-md text-on-surface-variant uppercase pb-sm">Coste</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
              {vehicleMaintenances.map((m) => (
                <tr>
                  <td class="py-sm text-body-md text-on-surface">
                    {maintenanceTypes[m.type] || m.type}
                  </td>
                  <td class="py-sm text-body-md text-on-surface-variant">
                    {m.date ? new Date(m.date).toLocaleDateString('es-ES') : '-'}
                  </td>
                  <td class="py-sm font-mono text-data-mono text-on-surface-variant">
                    {m.km?.toLocaleString() || '-'}
                  </td>
                  <td class="py-sm text-body-md text-on-surface text-right font-mono">
                    {m.cost ? `${m.cost.toFixed(2)} €` : '-'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </Card>

    {/* Quick actions */}
    <div class="flex items-center gap-md">
      <Button href={`/maintenance/${id}?new=true`} variant="secondary">
        + Añadir mantenimiento
      </Button>
      <Button href={`/fuel/${id}?new=true`} variant="secondary">
        + Registrar repostaje
      </Button>
    </div>
  </div>
</AppLayout>
