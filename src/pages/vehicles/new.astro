---
import AppLayout from '../../layouts/AppLayout.astro';
import VehicleForm from '../../components/vehicles/VehicleForm.astro';
import Card from '../../components/ui/Card.astro';
import { db } from '../../db/client';
import { vehicles } from '../../db/schema';
import { createId } from '@paralleldrive/cuid2';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const plate = formData.get('plate')?.toString().toUpperCase();
  const vin = formData.get('vin')?.toString().toUpperCase() || null;
  const brand = formData.get('brand')?.toString();
  const model = formData.get('model')?.toString();
  const year = formData.get('year')?.toString();
  const color = formData.get('color')?.toString() || null;
  const fuelType = formData.get('fuelType')?.toString() || null;
  const km = formData.get('km')?.toString();

  if (plate && brand && model) {
    const vehicleId = createId();

    await db.insert(vehicles).values({
      id: vehicleId,
      userId: Astro.locals.user.id,
      plate,
      vin,
      brand,
      model,
      year: year ? parseInt(year) : null,
      color,
      fuelType,
      km: km ? parseInt(km) : 0,
      createdAt: Date.now(),
    });

    return Astro.redirect(`/vehicles/${vehicleId}`);
  }
}
---

<AppLayout title="Nuevo vehículo">
  <div class="max-w-2xl">
    <div class="mb-lg">
      <a href="/vehicles" class="text-body-md text-on-surface-variant hover:text-primary transition-colors">
        ← Volver a vehículos
      </a>
      <h1 class="text-headline-lg text-on-surface mt-sm">Nuevo vehículo</h1>
      <p class="text-body-lg text-on-surface-variant mt-xs">Añade un vehículo a tu flota</p>
    </div>

    <Card>
      <VehicleForm action="/vehicles/new" />
    </Card>
  </div>
</AppLayout>
