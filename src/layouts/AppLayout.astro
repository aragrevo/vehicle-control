---
interface Props {
  title: string;
}

const { title } = Astro.props;
const { user } = Astro.locals;

const navItems = [
  { href: '/vehicles', label: 'Vehículos', icon: '🚗' },
  { href: '/maintenance', label: 'Mantenimiento', icon: '🔧' },
  { href: '/documents', label: 'Documentos', icon: '📄' },
  { href: '/fuel', label: 'Repostajes', icon: '⛽' },
  { href: '/expenses', label: 'Gastos', icon: '💰' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Control de vehículos" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Vehicle Control</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="flex min-h-screen">
      {/* Sidebar */}
      <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-6 border-b border-gray-200">
          <h1 class="text-xl font-bold text-gray-900">🚗 Vehicle Control</h1>
          <p class="text-sm text-gray-500 mt-1">Gestión de flota</p>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPath.startsWith(item.href)
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-gray-700 hover:bg-gray-100'
              }`}
            >
              <span>{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        {user && (
          <div class="p-4 border-t border-gray-200">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 text-sm font-medium">
                  {user.name?.[0] || user.email[0].toUpperCase()}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate">
                  {user.name || 'Usuario'}
                </p>
                <p class="text-xs text-gray-500 truncate">{user.email}</p>
              </div>
            </div>
            <form method="POST" action="/api/auth/logout" class="mt-3">
              <button
                type="submit"
                class="w-full text-left text-sm text-gray-500 hover:text-gray-700 px-3 py-2 rounded-lg hover:bg-gray-100"
              >
                Cerrar sesión
              </button>
            </form>
          </div>
        )}
      </aside>

      {/* Main content */}
      <main class="flex-1 p-8">
        <slot />
      </main>
    </div>
  </body>
</html>
