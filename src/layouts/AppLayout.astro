---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { user } = Astro.locals;

const navItems = [
  { href: '/vehicles', label: 'Vehículos', icon: '🚗' },
  { href: '/maintenance', label: 'Mantenimiento', icon: '🔧' },
  { href: '/documents', label: 'Documentos', icon: '📄' },
  { href: '/fuel', label: 'Repostajes', icon: '⛽' },
  { href: '/expenses', label: 'Gastos', icon: '💰' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Control de vehículos" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Vehicle Control</title>
  </head>
  <body class="bg-surface text-on-surface min-h-screen">
    <div class="flex min-h-screen">
      {/* Sidebar */}
      <aside class="w-64 bg-surface-container border-r border-outline-variant flex flex-col">
        <div class="p-lg border-b border-outline-variant">
          <div class="flex items-center gap-sm">
            <div class="w-8 h-8 bg-primary/20 rounded-md flex items-center justify-center">
              <span class="text-primary text-lg">🚗</span>
            </div>
            <div>
              <h1 class="text-headline-sm font-bold text-on-surface">Fleet</h1>
              <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Control</p>
            </div>
          </div>
        </div>

        <nav class="flex-1 p-sm space-y-xs">
          {navItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`flex items-center gap-sm px-md py-sm rounded-md text-body-md font-medium transition-colors ${
                  isActive
                    ? 'bg-primary/10 text-primary'
                    : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface'
                }`}
              >
                <span class="text-lg">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            );
          })}
        </nav>

        {user && (
          <div class="p-md border-t border-outline-variant">
            <div class="flex items-center gap-sm">
              <div class="w-8 h-8 bg-secondary/20 rounded-full flex items-center justify-center">
                <span class="text-secondary text-label-md font-bold">
                  {user.name?.[0] || user.email[0].toUpperCase()}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-body-md font-medium text-on-surface truncate">
                  {user.name || 'Usuario'}
                </p>
                <p class="text-label-md text-on-surface-variant truncate">{user.email}</p>
              </div>
            </div>
            <form method="POST" action="/api/auth/logout" class="mt-sm">
              <button
                type="submit"
                class="w-full text-left text-body-md text-on-surface-variant hover:text-on-surface px-sm py-xs rounded-md hover:bg-surface-container-high transition-colors"
              >
                Cerrar sesión
              </button>
            </form>
          </div>
        )}
      </aside>

      {/* Main content */}
      <main class="flex-1 p-lg overflow-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
