---
import '@/styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { user } = Astro.locals;

const navItems = [
  { href: '/vehicles', label: 'Vehículos', icon: 'directions_car' },
  { href: '/maintenance', label: 'Mantenimiento', icon: 'build' },
  { href: '/documents', label: 'Documentos', icon: 'description' },
  { href: '/fuel', label: 'Combustible', icon: 'local_gas_station' },
  { href: '/expenses', label: 'Gastos', icon: 'payments' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Control de vehículos" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Vehicle Control</title>
  </head>
  <body class="font-body-md text-body-md overflow-hidden">
    <div class="flex h-screen w-full">
      {/* SideNavBar */}
      <aside class="hidden md:flex flex-col h-screen py-lg space-y-md bg-surface border-r border-outline-variant w-64 flex-shrink-0">
        <div class="px-md mb-lg">
          <h1 class="text-headline-sm font-bold text-on-surface">Vehicle</h1>
              <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Control</p>
        </div>
        <nav class="flex-1 px-sm space-y-1">
          {navItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-md py-sm transition-colors rounded-md ${
                  isActive
                    ? 'bg-secondary-container text-on-secondary-container'
                    : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest'
                }`}
              >
                <span class="material-symbols-outlined">{item.icon}</span>
                <span class="font-label-md">{item.label}</span>
              </a>
            );
          })}
        </nav>
        <div class="mt-auto px-sm pt-md border-t border-outline-variant space-y-1">
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="w-full flex items-center gap-3 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest px-md py-sm transition-colors rounded-lg"
            >
              <span class="material-symbols-outlined">logout</span>
              <span class="font-label-md">Cerrar sesión</span>
            </button>
          </form>
        </div>
      </aside>

      {/* Main Content Area */}
      <div class="flex-1 flex flex-col min-w-0 bg-background overflow-hidden relative">
        {/* TopAppBar */}
        <header class="flex justify-between items-center w-full px-md h-16 bg-surface-container border-b border-outline-variant sticky top-0 z-30">
          <div class="flex items-center gap-md">
            <button id="menu-toggle" class="md:hidden material-symbols-outlined text-on-surface">menu</button>
            <h2 class="font-headline-md text-headline-md font-bold text-primary">{title}</h2>
          </div>
          <div class="flex items-center gap-md">
            <div class="hidden lg:flex items-center bg-surface-container-lowest border border-outline-variant rounded-full px-md py-1.5 w-64">
              <span class="material-symbols-outlined text-on-surface-variant mr-2">search</span>
              <input
                class="bg-transparent border-none outline-none text-on-surface placeholder-on-surface-variant text-body-md w-full focus:ring-0"
                placeholder="Buscar vehículo..."
                type="text"
              />
            </div>
            <button class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container-high p-2 rounded-full transition-colors">
              notifications
            </button>
            <div class="w-8 h-8 rounded-full bg-secondary-container overflow-hidden border border-outline-variant flex items-center justify-center">
              <span class="text-secondary text-label-md font-bold">
                {user?.name?.[0] || user?.email?.[0]?.toUpperCase() || 'U'}
              </span>
            </div>
          </div>
        </header>

        {/* Scrollable Content */}
        <main class="flex-1 overflow-y-auto p-md lg:p-xl">
          <slot />
        </main>

        {/* BottomNavBar (Mobile Only) */}
        <nav class="md:hidden flex justify-between items-center w-full px-md h-16 bg-surface-container border-t border-outline-variant fixed bottom-0 z-40">
          <a class="flex flex-col items-center justify-center text-on-surface-variant" href="/vehicles">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="text-[10px] mt-0.5">Inicio</span>
          </a>
          <a class="flex flex-col items-center justify-center text-primary" href="/vehicles">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">directions_car</span>
            <span class="text-[10px] mt-0.5 font-bold">Vehículos</span>
          </a>
          <div class="relative -top-6">
            <a href="/vehicles/new" class="w-14 h-14 bg-primary text-on-primary-fixed rounded-full shadow-2xl flex items-center justify-center">
              <span class="material-symbols-outlined text-[32px]" style="font-variation-settings: 'wght' 600;">add</span>
            </a>
          </div>
          <a class="flex flex-col items-center justify-center text-on-surface-variant" href="/documents">
            <span class="material-symbols-outlined">description</span>
            <span class="text-[10px] mt-0.5">Docs</span>
          </a>
          <a class="flex flex-col items-center justify-center text-on-surface-variant" href="#">
            <span class="material-symbols-outlined">person</span>
            <span class="text-[10px] mt-0.5">Perfil</span>
          </a>
        </nav>
      </div>
    </div>

    {/* Mobile menu overlay */}
    <div id="mobile-menu" class="fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/50" id="menu-overlay"></div>
      <aside class="absolute left-0 top-0 h-full w-64 bg-surface border-r border-outline-variant p-lg space-y-md">
        <div class="mb-lg">
          <h1 class="font-headline-sm text-headline-sm font-bold text-primary">FleetControl</h1>
          <p class="text-on-surface-variant font-label-md mt-1">Vista Operativa</p>
        </div>
        <nav class="space-y-1">
          {navItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-md py-sm transition-colors rounded-lg ${
                  isActive
                    ? 'bg-secondary-container text-on-secondary-container'
                    : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest'
                }`}
              >
                <span class="material-symbols-outlined">{item.icon}</span>
                <span class="font-label-md">{item.label}</span>
              </a>
            );
          })}
        </nav>
      </aside>
    </div>

    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuOverlay = document.getElementById('menu-overlay');

      menuToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      menuOverlay?.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
      });
    </script>
  </body>
</html>
